{
  "env": {
    "browser": true,
    "es2021": true
  },
  "plugins": ["react", "react-hooks"],
  "rules": {
    "no-undef": "off",
    "no-unused-vars": "warn",
    "react-hooks/rules-of-hooks": "error",
    "react-hooks/exhaustive-deps": "warn"
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "ecmaFeatures": { "jsx": true }
  }
}
