rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    // The app keys all user data by canonicalUid = lowercase email prefix
    // (01-core.js canonicalUid). A signed-in, email-verified user owns exactly
    // the /users/{prefix} tree whose prefix matches their own email — that is
    // the whole multi-user compartment model. (Known limitation, documented in
    // HANDOFF: two different addresses with the same prefix would collide; the
    // durable fix is a uid-keyed storage migration, which is a guarded
    // storage refactor — not done in rules.)
    function isVerifiedSelf(userId) {
      return isAuthenticated()
        && request.auth.token.email_verified == true
        && request.auth.token.email is string
        && request.auth.token.email.lower().split('@')[0] == userId;
    }
    // The owner's accounts — full access (both map to the same person; the
    // rabbi account is primary and holds the live data).
    function isAdmin() {
      return isAuthenticated()
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'rabbidanziger@hocsouthbend.com',
          'ydanziger20@gmail.com'
        ];
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function isValidShaila(data) {
      return data.keys().hasAll(['content', 'status', 'createdAt', 'userId']) &&
             data.content is string && data.content.size() > 0 && data.content.size() < 100000 &&
             data.status in ['pending', 'answered', 'got_back'] &&
             data.userId is string;
    }

    // Main app data — each verified user reads/writes ONLY their own
    // email-prefix compartment; the owner's accounts see everything.
    match /users/{userId}/{document=**} {
      allow read, write: if isAdmin() || isVerifiedSelf(userId);
    }

    match /shailos/{shailaId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAdmin() && isValidShaila(request.resource.data);
      allow update: if isAdmin() && isValidShaila(request.resource.data);
      allow delete: if isAdmin();
    }

    // ── Phone relay — the owner's single phone channel ──────────────────────
    // state/media are READ-gated to the owner's accounts: the phone-relay
    // function verifies callers by reading `state` WITH their ID token, so
    // this one rule also locks the function's state + command endpoints to
    // the owner. Other signed-in users simply see "no phone link".
    // Writes stay open because the native hosts push with only the public API
    // key (no auth token) — tightening writes requires a host rebuild
    // (tracked in backend security followups).
    match /phone-relay/state {
      allow read: if isAdmin();
      allow write: if true;
    }
    match /phone-relay/commands {
      allow read, write: if true;
    }
    // Host arbitration doc (phone-host-control.js / RelayService.cs / RelayClient.kt).
    // Carries only "which host holds the phone" + a heartbeat; hosts touch it
    // unauthenticated. Reads stay open (needed by the web toggle pre-auth),
    // writes too — nothing private inside.
    match /phone-relay/owner {
      allow read, write: if true;
    }
    // Message media (MMS images) — owner-only reads, host (unauthenticated) writes.
    match /phone-media/{imageId} {
      allow read: if isAdmin();
      allow write: if true;
    }
    // Live "which AI lane is serving requests" status (_ai-core.cjs recordAiLaneEvent) —
    // owner-only read for the status chip; only the Function's Admin SDK writes it, so
    // client writes stay fully closed.
    match /_system/ai-status {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
