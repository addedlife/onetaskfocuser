<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon. The background color is a gradle resValue that cycles
     a palette per build (see app/build.gradle.kts hostBuild) so each installed
     build is recognizable at a glance on the home screen. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_bg" />
    <foreground android:drawable="@drawable/ic_launcher_fg" />
</adaptive-icon>
