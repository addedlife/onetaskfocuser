rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: shailos
    // Document ID: auto-generated
    // Fields:
    //   - date: string (ISO 8601)
    //   - askerName: string (optional)
    //   - content: string (required)
    //   - parsedShaila: string (optional)
    //   - answer: string (optional)
    //   - answererName: string (optional)
    //   - reasons: string (optional)
    //   - status: string (required, enum: ["pending", "answered"])
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (optional)
    //   - userId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "rabbidanziger@hocsouthbend.com" && request.auth.token.email_verified == true);
    }

    function isValidShaila(data) {
      return data.keys().hasAll(['content', 'status', 'createdAt', 'userId']) &&
             data.content is string && data.content.size() > 0 && data.content.size() < 100000 &&
             data.status in ['pending', 'answered'] &&
             data.userId == request.auth.uid;
    }

    // Main app data — each user can only read/write their own subtree.
    // Covers: users/{uid}/appData, users/{uid}/tasks, users/{uid}/config, users/{uid}/shailos
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /shailos/{shailaId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidShaila(request.resource.data);
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && isValidShaila(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    // Phone relay — temporary mailbox data for DeskPhone ↔ web bridge.
    //
    // State document (PII: messages, contacts, call log):
    //   - Read: requires Firebase auth — only authenticated users can fetch phone data.
    //   - Write: open at Firestore layer; the Netlify function enforces X-Relay-Secret before writing.
    //
    // Commands document (outgoing command queue):
    //   - Open read/write: DeskPhone drains it without a Firebase token (uses relay secret).
    //     The Netlify function gates command writes behind Firebase auth before reaching Firestore.
    match /phone-relay/state {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /phone-relay/commands {
      allow read, write: if true;
    }

    // Picture-text image previews — one resized image per document.
    //   - Read: requires Firebase auth (only the signed-in user sees their pictures).
    //   - Write: open at the Firestore layer; the Netlify function gates push-media
    //     behind the X-Relay-Secret before writing.
    match /phone-media/{imageId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
  }
}
