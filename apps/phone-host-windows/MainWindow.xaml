<Window x:Class="DeskPhone.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DeskPhone.ViewModels"
        xmlns:helpers="clr-namespace:DeskPhone.Helpers"
        Title="{Binding WindowTitle}"
        Height="820" Width="1580" MinHeight="600" MinWidth="940"
        Background="{DynamicResource BgMain}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.ClearTypeHint="Enabled"
        FontFamily="{StaticResource MaterialFontFamily}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="MaterialIconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MaterialIconsRoundFont}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>

        <Style x:Key="CompactIconButton" TargetType="Button" BasedOn="{StaticResource TonalButton}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontFamily" Value="{StaticResource MaterialIconsRoundFont}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="ThreadSearchGlyphButton" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,0,0,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="FontFamily" Value="{StaticResource MaterialIconsRoundFont}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThreadSearchBoxContainer" TargetType="Border">
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Background" Value="{DynamicResource BgInput}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ThreadSearchTextBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="ThreadSearchStatusText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="6,0,4,0"/>
        </Style>

        <Style x:Key="CompactHeaderActionButton" TargetType="Button" BasedOn="{StaticResource OutlinedButton}">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="CollapsedRailIconButton" TargetType="Button" BasedOn="{StaticResource CompactIconButton}">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CallRowActionButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactIconButton}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BubbleActionButtonStyle" TargetType="Button" BasedOn="{StaticResource TonalButton}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontFamily" Value="{StaticResource MaterialIconsRoundFont}"/>
        </Style>

        <Style x:Key="BubbleActionPinButtonStyle" TargetType="Button" BasedOn="{StaticResource BubbleActionButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarLinkButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextSecond}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="8,2,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource MaterialFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource BgHover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="{DynamicResource BgSelected}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding DataContext.IsNavigationRailCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="12,4,12,0"/>
                                <Setter Property="Width" Value="52"/>
                                <Setter Property="Height" Value="48"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SwitchToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="{DynamicResource BgInput}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                            <Border x:Name="Track"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="19"/>
                            <TextBlock x:Name="OffLabel"
                                       Text="Off"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"/>
                            <TextBlock x:Name="OnLabel"
                                       Text="On"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextOnAccent}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Visibility="Collapsed"/>
                            <Ellipse x:Name="Thumb"
                                     Width="26"
                                     Height="26"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="6,0,0,0"
                                     Fill="{DynamicResource TextPrimary}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBlue}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,6,0"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="{DynamicResource BgMain}"/>
                                <Setter TargetName="OffLabel" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="OnLabel" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Track" Property="Opacity" Value="0.45"/>
                                <Setter TargetName="Thumb" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MessageListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuggestionListBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgMain}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
        </Style>

        <Style x:Key="SuggestionListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource TouchListBoxStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="SuggestionListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuggestionRowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BgSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HorizontalMacSplitter" TargetType="GridSplitter">
            <Setter Property="Height" Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="SizeNS"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="Transparent" Height="{TemplateBinding Height}">
                            <Rectangle x:Name="line" Height="1"
                                       Fill="{DynamicResource Border}"
                                       VerticalAlignment="Center"
                                       Opacity="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="line"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.45" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="line"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

<Grid x:Name="RootShellGrid"
      Background="{DynamicResource BgMain}"
      ClipToBounds="True"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      TextOptions.TextFormattingMode="Display"
      TextOptions.TextRenderingMode="ClearType"
      TextOptions.TextHintingMode="Fixed"
      RenderOptions.ClearTypeHint="Enabled">
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding UiScale}" ScaleY="{Binding UiScale}"/>
        </Grid.LayoutTransform>
        <Grid.ColumnDefinitions>
            <!-- Navigation rail -->
            <ColumnDefinition x:Name="RootNavigationColumn" Width="292" MinWidth="224" MaxWidth="360"/>
            <ColumnDefinition Width="Auto"/>
            <!-- Content area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================================================================ -->
        <!-- LEFT RAIL  -  Google Material Navigation Drawer style             -->
        <!-- ================================================================ -->
        <Border Grid.Column="0"
                Background="{DynamicResource BgSidebar}"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- App identity -->
                <Grid Grid.Row="0" Margin="18,24,16,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" MinWidth="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" CornerRadius="9"
                                Background="{DynamicResource AccentBlue}" Margin="0,0,12,0">
                            <TextBlock Text="&#xE0B7;" Style="{StaticResource MaterialIconText}" FontSize="20"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="White" Margin="0,-1,0,0"/>
                        </Border>
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    MinWidth="0"
                                    Visibility="{Binding ShowNavigationRailLabels, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="DeskPhone"
                                       FontSize="22" FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding BuildNumberLabel}"
                                       Margin="0,2,0,0"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextMuted}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding BuildNumberLabel}"/>
                            <TextBlock Text="{Binding BuildTimeLabel}"
                                       Margin="0,2,0,0"
                                       FontSize="11"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextMuted}"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding BuildTimeLabel}"/>
                        </StackPanel>
                    </Grid>
                    <Button Grid.Row="0"
                            Grid.Column="1"
                            AutomationProperties.Name="{Binding NavigationRailToggleLabel}"
                            AutomationProperties.AutomationId="NavigationRailToggleButton"
                            Style="{StaticResource CompactIconButton}"
                            Width="36"
                            Height="36"
                            Margin="8,0,0,0"
                            Content="{Binding NavigationRailToggleGlyph}"
                            ToolTip="{Binding NavigationRailToggleLabel}"
                            Command="{Binding ToggleNavigationRailCommand}"/>
                </Grid>

                <Button Grid.Row="1"
                        AutomationProperties.Name="New message"
                        AutomationProperties.AutomationId="NewMessageButton"
                        FontSize="14"
                        Click="NewMessageButton_Click"
                        ToolTip="New message">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Margin" Value="16,0,16,20"/>
                            <Setter Property="Height" Value="48"/>
                            <Setter Property="Padding" Value="16,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNavigationRailCollapsed}" Value="True">
                            <Setter Property="Margin" Value="14,0,14,20"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Width" Value="56"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE3C9;"
                                   Grid.Column="0"
                                   Style="{StaticResource MaterialIconText}"
                                   FontSize="20"
                                   Width="56"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="New Message"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding ShowNavigationRailLabels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>
                </Button>

                <!-- Nav items -->
                <StackPanel Grid.Row="2" Margin="8,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNavigationRailCollapsed}" Value="True">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <RadioButton x:Name="TabMessages"
                                 AutomationProperties.Name="Phone"
                                 AutomationProperties.AutomationId="NavMessages"
                                 GroupName="Nav" IsChecked="True"
                                 Tag="Messages"
                                 Checked="NavigationTab_Checked"
                                 Style="{StaticResource NavButton}"
                                 ToolTip="Phone: messages and calls">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE0CA;" Style="{StaticResource MaterialIconText}" FontSize="21" Width="30"
                                       VerticalAlignment="Center" Margin="0,-2,0,0"/>
                            <TextBlock Text="Phone"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowNavigationRailLabels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </RadioButton>

                    <Button Style="{StaticResource SidebarLinkButtonStyle}"
                            AutomationProperties.Name="Make a call"
                            AutomationProperties.AutomationId="NavMakeCall"
                            Click="MakeCallButton_Click"
                            ToolTip="Make a call"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE0B0;"
                                       Style="{StaticResource MaterialIconText}"
                                       FontSize="21"
                                       Width="30"
                                       VerticalAlignment="Center"
                                       Margin="0,-2,0,0"/>
                            <TextBlock Text="Make Call"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowNavigationRailLabels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>

                    <RadioButton x:Name="TabCalls"
                                 AutomationProperties.Name="Calls"
                                 AutomationProperties.AutomationId="NavCalls"
                                 GroupName="Nav"
                                 Tag="Calls"
                                 Checked="NavigationTab_Checked"
                                 Style="{StaticResource NavButton}"
                                 ToolTip="Calls"
                                 Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE0B0;" Style="{StaticResource MaterialIconText}" FontSize="21" Width="30"
                                       VerticalAlignment="Center" Margin="0,-2,0,0"/>
                            <TextBlock Text="Calls"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowNavigationRailLabels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="TabContacts"
                                 AutomationProperties.Name="Contacts"
                                 AutomationProperties.AutomationId="NavContacts"
                                 GroupName="Nav"
                                 Tag="Contacts"
                                 Checked="NavigationTab_Checked"
                                 Style="{StaticResource NavButton}"
                                 ToolTip="Contacts">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7FD;"
                                       Style="{StaticResource MaterialIconText}"
                                       FontSize="21"
                                       Width="30"
                                       VerticalAlignment="Center"
                                       Margin="0,-2,0,0"/>
                            <TextBlock Text="Contacts"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowNavigationRailLabels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </RadioButton>

                    <Rectangle Fill="{DynamicResource Border}" Height="1" Margin="16,12"
                               Visibility="{Binding ShowNavigationRailLabels, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <RadioButton x:Name="TabSettings"
                                 AutomationProperties.Name="Settings"
                                 AutomationProperties.AutomationId="NavSettings"
                                 GroupName="Nav"
                                 Tag="Settings"
                                 Checked="NavigationTab_Checked"
                                 Style="{StaticResource NavButton}"
                                 ToolTip="Settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B8;" Style="{StaticResource MaterialIconText}" FontSize="21" Width="30"
                                       VerticalAlignment="Center" Margin="0,-2,0,0"/>
                            <TextBlock Text="Settings"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowNavigationRailLabels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="TabDeveloperTools"
                                 AutomationProperties.Name="Developer Tools"
                                 AutomationProperties.AutomationId="NavDeveloperTools"
                                 GroupName="Nav"
                                 Tag="DeveloperTools"
                                 Checked="NavigationTab_Checked"
                                 Style="{StaticResource NavButton}"
                                 ToolTip="Developer Tools">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE869;" Style="{StaticResource MaterialIconText}" FontSize="21" Width="30"
                                       VerticalAlignment="Center" Margin="0,-2,0,0"/>
                            <TextBlock Text="Developer Tools"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowNavigationRailLabels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </RadioButton>

                    <Button Style="{StaticResource SidebarLinkButtonStyle}"
                            AutomationProperties.Name="Live Log"
                            AutomationProperties.AutomationId="NavLiveLog"
                            Click="OpenLiveLogButton_Click"
                            ToolTip="Open or focus the live log window"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEB8E;" Style="{StaticResource MaterialIconText}" FontSize="20" Width="30"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Live Log"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding ShowNavigationRailLabels, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Connection status pill -->
                <Border Grid.Row="3" Padding="20,16">
                    <Grid>
                        <StackPanel Visibility="{Binding ShowNavigationRailLabels, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Background="{DynamicResource BgInput}" CornerRadius="12" Padding="12,10">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource TextDisabled}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFullyConnected}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource AccentGreen}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding ConnectionStatus}"
                                                       FontSize="12" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                AutomationProperties.Name="Reconnect saved phone"
                                                AutomationProperties.AutomationId="RailReconnectIconButton"
                                                Style="{StaticResource CompactIconButton}"
                                                Content="&#xE627;"
                                                Margin="8,0,0,0"
                                                Command="{Binding ConnectQuickDeviceCommand}"
                                                ToolTip="Clean reconnect to saved device"
                                                Visibility="{Binding HasQuickConnectDevice, Converter={StaticResource BoolToVisibilityConverter}}"
                                                IsEnabled="{Binding CanQuickReconnect}"/>
                                    </Grid>
                                    <TextBlock Text="{Binding ConnectionRailSubtitle}"
                                               Margin="16,7,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap"
                                               LineHeight="15"/>
                                    <TextBlock Text="{Binding CallsConnectionLabel}"
                                               Margin="16,9,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"/>
                                    <TextBlock Text="{Binding MessagesConnectionLabel}"
                                               Margin="16,3,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                            </Border>
                            <Button Margin="0,10,0,8"
                                    AutomationProperties.Name="Reconnect saved phone"
                                    AutomationProperties.AutomationId="RailReconnectButton"
                                    Content="{Binding QuickConnectSidebarLabel}"
                                    Style="{StaticResource TonalButton}"
                                    Height="38"
                                    Padding="16,0"
                                    Command="{Binding ConnectQuickDeviceCommand}"
                                    Visibility="{Binding HasQuickConnectDevice, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Button Content="Connection Settings"
                                    AutomationProperties.Name="Connection Settings"
                                    AutomationProperties.AutomationId="RailConnectionSettingsButton"
                                    Style="{StaticResource TonalButton}"
                                    Height="36"
                                    Padding="16,0"
                                    Click="OpenConnectionSettingsButton_Click"/>
                        </StackPanel>

                        <StackPanel HorizontalAlignment="Center"
                                    Visibility="{Binding IsNavigationRailCollapsed, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Width="52"
                                    Height="52"
                                    Background="{DynamicResource BgInput}"
                                    CornerRadius="12"
                                    ToolTip="{Binding ConnectionStatus}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse Width="10" Height="10" Margin="0,11,0,6">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource TextDisabled}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFullyConnected}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource AccentGreen}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="BT"
                                               FontSize="11"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource TextMuted}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Button Style="{StaticResource CollapsedRailIconButton}"
                                    AutomationProperties.Name="Reconnect saved phone"
                                    AutomationProperties.AutomationId="CollapsedRailReconnectButton"
                                    Content="&#xE627;"
                                    Command="{Binding ConnectQuickDeviceCommand}"
                                    ToolTip="{Binding QuickConnectSidebarLabel}"
                                    Visibility="{Binding HasQuickConnectDevice, Converter={StaticResource BoolToVisibilityConverter}}"
                                    IsEnabled="{Binding CanQuickReconnect}"/>
                            <Button Style="{StaticResource CollapsedRailIconButton}"
                                    AutomationProperties.Name="Connection settings"
                                    AutomationProperties.AutomationId="CollapsedRailConnectionSettingsButton"
                                    Content="&#xE8B8;"
                                    ToolTip="Connection settings"
                                    Click="OpenConnectionSettingsButton_Click"/>
                            <Border Width="52"
                                    Margin="0,10,0,0"
                                    Padding="4,5"
                                    Background="{DynamicResource BgInput}"
                                    CornerRadius="10"
                                    ToolTip="{Binding BuildBadge}">
                                <TextBlock Text="{Binding BuildBadge}"
                                           FontSize="11"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource TextMuted}"
                                           TextAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <GridSplitter x:Name="ShellNavigationSplitter" Grid.Column="1" Style="{StaticResource MacSplitter}"/>

        <!-- ================================================================ -->
        <!-- RIGHT CONTENT AREA                                               -->
        <!-- ================================================================ -->
        <Grid Grid.Column="2" Background="{DynamicResource BgSidebar}">
            <Grid.RowDefinitions>
                <!-- Reconnect prompt banner -->
                <RowDefinition Height="Auto"/>
                <!-- Contact import prompt -->
                <RowDefinition Height="Auto"/>
                <!-- Active call banner -->
                <RowDefinition Height="Auto"/>
                <!-- Tab content -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Reconnect prompt -->
            <Border Grid.Row="0"
                    Margin="24,16,24,0" CornerRadius="12" Padding="18,13"
                    Background="{DynamicResource AccentBlueLight}"
                    BorderBrush="{DynamicResource AccentBlue}" BorderThickness="1"
                    Visibility="{Binding ShowReconnectPrompt,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock FontSize="14" FontWeight="Medium"
                                   Foreground="{DynamicResource AccentBlue}"
                                   Text="{Binding ReconnectPromptText}"/>
                        <TextBlock Text="Your phone was connected last session."
                                   FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Connect"
                            Style="{StaticResource PrimaryButton}"
                            Padding="20,0" Height="36" Margin="12,0,8,0"
                            Command="{Binding ReconnectCommand}"/>
                    <Button Grid.Column="2" Content="Choose device"
                            Style="{StaticResource TonalButton}"
                            Height="36" Padding="16,0" Margin="0,0,8,0"
                            Click="ChooseDeviceButton_Click"/>
                    <Button Grid.Column="3" Content="&#xE5CD;"
                            Style="{StaticResource CompactIconButton}"
                            Width="36" Height="36" Padding="0"
                            Command="{Binding DismissReconnectCommand}"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="24,12,24,0" CornerRadius="12" Padding="18,13"
                    Background="{DynamicResource AccentGreenLight}"
                    BorderBrush="{DynamicResource AccentGreenDark}" BorderThickness="1"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ContactImportPromptText}"
                                   FontSize="14" FontWeight="Medium"
                                   Foreground="{DynamicResource AccentGreenDark}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ContactSyncFolderPath}"
                                   FontSize="12" Foreground="{DynamicResource TextMuted}"
                                   Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Yes"
                            Style="{StaticResource SuccessButton}"
                            Padding="20,0" Height="36" Margin="12,0,8,0"
                            Command="{Binding ImportPendingContactsCommand}"/>
                    <Button Grid.Column="2" Content="No"
                            Style="{StaticResource TonalButton}"
                            Height="36" Padding="16,0"
                            Command="{Binding SkipPendingContactsCommand}"/>
                </Grid>
            </Border>

            <!-- Active call / ringing banner -->
            <Border Grid.Row="0" Grid.RowSpan="4"
                    Panel.ZIndex="520"
                    Background="#66081420"
                    Visibility="{Binding ShowBuildUpdatePrompt,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid Margin="24">
                    <Border Width="460"
                            MaxWidth="460"
                            Padding="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            CornerRadius="12"
                            Background="{DynamicResource BgMain}"
                            BorderBrush="{DynamicResource Border}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding BuildUpdateTitle}"
                                       FontSize="22"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="{Binding BuildUpdateBody}"
                                       Margin="0,12,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecond}"
                                       TextWrapping="Wrap"
                                       LineHeight="22"/>
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="Use New Build"
                                        Style="{StaticResource PrimaryButton}"
                                        Padding="22,0"
                                        Margin="0,0,10,0"
                                        Command="{Binding AcceptBuildUpdateCommand}"/>
                                <Button Content="Not Yet"
                                        Style="{StaticResource TonalButton}"
                                        Padding="18,0"
                                        Command="{Binding SnoozeBuildUpdateCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.RowSpan="4"
                    Panel.ZIndex="510"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,16,24,0"
                    Visibility="{Binding ShowBuildUpdateIndicator,
                        Converter={StaticResource BoolToVisibilityConverter}}">
                <Button Style="{StaticResource TonalButton}"
                        Padding="14,8"
                        Command="{Binding ShowBuildUpdatePromptCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7F4;"
                                   Style="{StaticResource MaterialIconText}"
                                   FontSize="16"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="New Build Available"
                                   FontSize="12"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Border>

            <Border Grid.Row="2"
                    Margin="24,12,24,0" CornerRadius="16" Padding="16,12"
                    Panel.ZIndex="100">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="6" Direction="270"
                                      Color="#000000" Opacity="0.1"/>
                </Border.Effect>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility"   Value="Collapsed"/>
                        <Setter Property="Background"   Value="{DynamicResource BgMain}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRinging}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Background" Value="#EAF1FB"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsCallActive}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Setter Property="Background" Value="#E6F4EA"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12"
                            Margin="0,0,14,0" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource AccentGreen}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRinging}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="&#xE61D;" Style="{StaticResource MaterialIconText}" FontSize="22" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Grid.Column="1" Text="{Binding CallBannerText}"
                               FontSize="16" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Margin="0,0,10,0" Height="36" Padding="20,0"
                                Command="{Binding MuteMicCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Content" Value="Mute"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCallActive}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsMuted}" Value="True">
                                            <Setter Property="Content" Value="Unmute"/>
                                            <Setter Property="Background" Value="#FFCDD2"/>
                                            <Setter Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="Accept" Margin="0,0,10,0" Height="36" Padding="20,0"
                                Command="{Binding AnswerCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SuccessButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRinging}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Height="36" Padding="20,0"
                                Command="{Binding HangUpCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource DestructiveButton}">
                                    <Setter Property="Content" Value="Hang Up"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRinging}" Value="True">
                                            <Setter Property="Content" Value="Decline"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================================================================ -->
            <!-- TAB: MESSAGES                                                -->
            <!-- ================================================================ -->
            <Grid Grid.Row="3" x:Name="MessagesRootGrid">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=TabMessages}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <!-- Conversation list -->
                    <ColumnDefinition x:Name="MessagesListColumn" Width="300" MinWidth="210" MaxWidth="420"/>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Thread / compose view -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: conversation list -->
                <Border Grid.Column="0"
                        Background="{DynamicResource SurfaceContainerLow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="16,16,16,10">
                            <StackPanel>
                                <Grid Margin="4,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Messages"
                                               FontSize="22" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <!-- History loading indicator -->
                                    <Border Grid.Column="1" CornerRadius="10" Padding="8,3"
                                            Background="{DynamicResource AccentBlueLight}"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding FullHistoryStatus,
                                                Converter={StaticResource NullOrEmptyToCollapsedConverter}}">
                                        <TextBlock Text="{Binding FullHistoryStatus}"
                                                   FontSize="11" FontWeight="Medium"
                                                   Foreground="{DynamicResource AccentBlue}"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="&#xE145;"
                                                Style="{StaticResource CompactIconButton}"
                                                Margin="4,0,0,0"
                                                Click="NewMessageButton_Click"
                                                ToolTip="New message"/>
                                        <Button Content="&#xE164;"
                                                Command="{Binding ToggleConversationSortCommand}"
                                                Margin="4,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource CompactIconButton}">
                                                    <Setter Property="ToolTip" Value="Sort: Recent first  -  click for Unread first"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUnreadFirstSortMode}" Value="True">
                                                            <Setter Property="ToolTip" Value="Sort: Unread first  -  click for Recent first"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="&#xE5CD;"
                                                Style="{StaticResource CompactIconButton}"
                                                Margin="4,0,0,0"
                                                Command="{Binding CloseMessagesListPaneCommand}"
                                                ToolTip="Hide threads"/>
                                    </StackPanel>
                                </Grid>
                                <!-- Search box -->
                                <Border CornerRadius="10" Background="{DynamicResource BgInput}"
                                        BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                        Padding="10,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="&#xE8B6;" Style="{StaticResource MaterialIconText}" FontSize="18"
                                                   VerticalAlignment="Center" Margin="2,0,6,0"
                                                   Foreground="{DynamicResource TextMuted}"/>
                                        <TextBox Grid.Column="1"
                                                 AutomationProperties.Name="Search conversations"
                                                 AutomationProperties.AutomationId="ConversationSearchBox"
                                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                 BorderThickness="0" Background="Transparent"
                                                 FontSize="14" VerticalAlignment="Center"
                                                 MinHeight="32"
                                                 Foreground="{DynamicResource TextPrimary}">
                                            <TextBox.Style>
                                                <Style TargetType="TextBox">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsFocused" Value="False">
                                                            <Setter Property="Tag" Value="Search..."/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBox.Style>
                                        </TextBox>
                                    </Grid>
                                </Border>
                                <UniformGrid Columns="5" Margin="0,10,0,0">
                                    <Button Content="All"
                                            AutomationProperties.Name="Show all conversations"
                                            AutomationProperties.AutomationId="ConversationFilterAll"
                                            Command="{Binding SetConversationFilterCommand}"
                                            CommandParameter="All"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                <Setter Property="Height" Value="32"/>
                                                <Setter Property="Padding" Value="8,0"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConversationFilterAll}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Unread"
                                            AutomationProperties.Name="Show unread conversations"
                                            AutomationProperties.AutomationId="ConversationFilterUnread"
                                            Command="{Binding SetConversationFilterCommand}"
                                            CommandParameter="Unread"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                <Setter Property="Height" Value="32"/>
                                                <Setter Property="Padding" Value="8,0"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConversationFilterUnread}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Pinned"
                                            AutomationProperties.Name="Show pinned conversations"
                                            AutomationProperties.AutomationId="ConversationFilterPinned"
                                            Command="{Binding SetConversationFilterCommand}"
                                            CommandParameter="Pinned"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                <Setter Property="Height" Value="32"/>
                                                <Setter Property="Padding" Value="8,0"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConversationFilterPinned}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Muted"
                                            AutomationProperties.Name="Show muted conversations"
                                            AutomationProperties.AutomationId="ConversationFilterMuted"
                                            Command="{Binding SetConversationFilterCommand}"
                                            CommandParameter="Muted"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                <Setter Property="Height" Value="32"/>
                                                <Setter Property="Padding" Value="8,0"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConversationFilterMuted}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Blocked"
                                            AutomationProperties.Name="Show blocked conversations"
                                            AutomationProperties.AutomationId="ConversationFilterBlocked"
                                            Command="{Binding SetConversationFilterCommand}"
                                            CommandParameter="Blocked">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                <Setter Property="Height" Value="32"/>
                                                <Setter Property="Padding" Value="8,0"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConversationFilterBlocked}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- Empty state -->
                        <StackPanel Grid.Row="1"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasVisibleConversations}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="&#xE0CA;" Style="{StaticResource MaterialIconText}" FontSize="48" Foreground="{DynamicResource Border}"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding ConversationEmptyStateText}"
                                       FontSize="16" FontWeight="Medium"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Conversation list -->
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Conversations}"
                                 SelectedItem="{Binding SelectedConversation}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding"         Value="16,14"/>
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush"     Value="{DynamicResource Border}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Cursor"          Value="Hand"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BgSelected}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Mark read"
                                                          Command="{Binding DataContext.MarkConversationReadCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Mark unread"
                                                          Command="{Binding DataContext.MarkConversationUnreadCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="Pin / unpin"
                                                          Command="{Binding DataContext.ToggleConversationPinnedCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Mute / unmute alerts"
                                                          Command="{Binding DataContext.ToggleConversationAlertsMutedCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          CommandParameter="{Binding}"/>
                                                <MenuItem Header="Block / unblock locally"
                                                          Command="{Binding DataContext.ToggleConversationBlockedCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          CommandParameter="{Binding}"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Avatar circle -->
                                        <Grid Grid.Column="0" Width="48" VerticalAlignment="Center">
                                            <Border Width="40" Height="40" CornerRadius="20"
                                                    Background="{DynamicResource AccentBlueLight}"
                                                    VerticalAlignment="Center" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding AvatarInitial}"
                                                           FontSize="16" FontWeight="Medium"
                                                           Foreground="{DynamicResource AccentBlue}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>

                                        <!-- Name + preview -->
                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding DisplayName}"
                                                           FontSize="18"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           TextTrimming="CharacterEllipsis">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontWeight" Value="Medium"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUnread}" Value="True">
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            Margin="10,0,0,0">
                                                    <TextBlock Text="Pinned"
                                                               FontSize="11"
                                                               FontWeight="Medium"
                                                               Foreground="{DynamicResource AccentBlue}"
                                                               Margin="0,0,8,0"
                                                               Visibility="{Binding IsPinned,
                                                                   Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <TextBlock Text="Alerts off"
                                                               FontSize="11"
                                                               FontWeight="Medium"
                                                               Foreground="{DynamicResource TextMuted}"
                                                               Margin="0,0,8,0"
                                                               Visibility="{Binding AreAlertsMuted,
                                                                   Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <TextBlock Text="Blocked"
                                                               FontSize="11"
                                                               FontWeight="Medium"
                                                               Foreground="{DynamicResource AccentRed}"
                                                               Visibility="{Binding IsBlocked,
                                                                   Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding TimestampDisplay}"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsUnread}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                                    <Setter Property="FontWeight" Value="Medium"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding PreviewText}"
                                                       FontSize="16"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,4,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUnread}" Value="True">
                                                                <Setter Property="FontWeight" Value="Medium"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <GridSplitter x:Name="MessagesListSplitter" Grid.Column="1" Style="{StaticResource MacSplitter}"/>

                <!-- Right: thread view + compose -->
                <Grid Grid.Column="2" Background="{DynamicResource BgMain}">

                    <!-- Empty placeholder -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                x:Name="NoConvPlaceholder"
                                Visibility="Collapsed">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedConversation}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Border Width="72" Height="72" CornerRadius="18"
                                Background="{DynamicResource BgHover}"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="&#xE0CA;" Style="{StaticResource MaterialIconText}" FontSize="36" Foreground="{DynamicResource Border}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Select a conversation"
                                   FontSize="16" FontWeight="Medium"
                                   Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="or start a new one"
                                   FontSize="14" Foreground="{DynamicResource TextDisabled}"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- Conversation thread view -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Contact header -->
                        <Border Grid.Row="0" Padding="24,14"
                                Visibility="Collapsed"
                                BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                                Background="{DynamicResource BgMain}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="12"
                                        Background="{DynamicResource AccentBlueLight}" Margin="0,0,14,0">
                                    <TextBlock Text="{Binding SelectedConversation.AvatarInitial}"
                                               FontSize="16" FontWeight="Medium"
                                               Foreground="{DynamicResource AccentBlue}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedConversation.DisplayName}"
                                               FontSize="16" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                     <TextBlock Text="{Binding SelectedConversation.FormattedPhone}"
                                                FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                Margin="0,1,0,0"/>
                                     <Border Style="{StaticResource ThreadSearchBoxContainer}"
                                             Margin="0,8,0,0"
                                             MaxWidth="520"
                                             HorizontalAlignment="Left">
                                         <Grid>
                                             <Grid.ColumnDefinitions>
                                                 <ColumnDefinition Width="Auto"/>
                                                 <ColumnDefinition Width="*"/>
                                                 <ColumnDefinition Width="Auto"/>
                                                 <ColumnDefinition Width="Auto"/>
                                                 <ColumnDefinition Width="Auto"/>
                                                 <ColumnDefinition Width="Auto"/>
                                             </Grid.ColumnDefinitions>
                                             <TextBlock Grid.Column="0" Text="&#xE8B6;" Style="{StaticResource MaterialIconText}" FontSize="16"
                                                        VerticalAlignment="Center" Margin="0,0,6,0"
                                                        Foreground="{DynamicResource TextMuted}"/>
                                             <TextBox Grid.Column="1"
                                                      AutomationProperties.Name="Search this conversation"
                                                      AutomationProperties.AutomationId="ThreadSearchBox"
                                                      Text="{Binding ConversationSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource ThreadSearchTextBox}"/>
                                             <TextBlock Grid.Column="2"
                                                        Text="{Binding ConversationSearchStatus}"
                                                        Style="{StaticResource ThreadSearchStatusText}"/>
                                             <Button Grid.Column="3" Content="&#xE316;"
                                                     Style="{StaticResource ThreadSearchGlyphButton}"
                                                     Command="{Binding ConversationSearchPreviousCommand}"
                                                     ToolTip="Previous match"/>
                                             <Button Grid.Column="4" Content="&#xE313;"
                                                     Style="{StaticResource ThreadSearchGlyphButton}"
                                                     Command="{Binding ConversationSearchNextCommand}"
                                                     ToolTip="Next match"/>
                                             <Button Grid.Column="5" Content="&#xE5CD;"
                                                     Style="{StaticResource ThreadSearchGlyphButton}"
                                                     Command="{Binding ClearConversationSearchCommand}"
                                                     ToolTip="Clear search"/>
                                         </Grid>
                                     </Border>
                                     <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="Pinned"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource AccentBlue}"
                                                   Margin="0,0,10,0"
                                                   Visibility="{Binding IsSelectedConversationPinned,
                                                       Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBlock Text="Alerts off"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   Margin="0,0,10,0"
                                                   Visibility="{Binding AreSelectedConversationAlertsMuted,
                                                       Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding SelectedConversationPinnedSummary}"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource AccentBlue}"
                                                   Margin="0,0,10,0"
                                                   Visibility="{Binding HasSelectedConversationPinnedMessages,
                                                       Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBlock Text="Blocked"
                                                   FontSize="11"
                                                   FontWeight="Medium"
                                                   Foreground="{DynamicResource AccentRed}"
                                                   Visibility="{Binding IsSelectedConversationBlocked,
                                                       Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                                <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="12,0,0,0">
                                    <Button Content="&#xE14B;"
                                            Style="{StaticResource CompactIconButton}"
                                            Command="{Binding ToggleConversationBlockedCommand}"
                                            ToolTip="{Binding SelectedConversationBlockTooltip}"/>
                                    <Button Content="&#xF10D;"
                                            Style="{StaticResource CompactIconButton}"
                                            Command="{Binding ToggleConversationPinnedCommand}"
                                            ToolTip="{Binding SelectedConversationPinTooltip}"/>
                                    <Button Content="&#xE7F6;"
                                            Style="{StaticResource CompactIconButton}"
                                            Command="{Binding ToggleConversationAlertsMutedCommand}"
                                            ToolTip="{Binding SelectedConversationAlertsTooltip}"/>
                                    <Button Content="&#xE151;"
                                            Style="{StaticResource CompactIconButton}"
                                            Command="{Binding MarkConversationReadCommand}"
                                            ToolTip="Mark read"
                                            Visibility="{Binding CanMarkSelectedConversationRead, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <Button Content="&#xF18A;"
                                            Style="{StaticResource CompactIconButton}"
                                            Command="{Binding MarkConversationUnreadCommand}"
                                            ToolTip="Mark unread"
                                            Visibility="{Binding CanMarkSelectedConversationUnread, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <Button Content="&#xE7FE;"
                                            Style="{StaticResource CompactIconButton}"
                                            Command="{Binding SaveAsContactCommand}"
                                            CommandParameter="{Binding SelectedConversation.PhoneNumber}"
                                            ToolTip="Add contact"
                                            Visibility="{Binding CanAddSelectedConversationContact, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <Button Content="&#xE3C9;"
                                            Style="{StaticResource CompactIconButton}"
                                            Command="{Binding EditContactCommand}"
                                            CommandParameter="{Binding SelectedConversationMatchingContact}"
                                            ToolTip="Edit contact"
                                            Visibility="{Binding CanEditSelectedConversationContact, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <Button Content="&#xE0B0;"
                                            Style="{StaticResource CompactIconButton}"
                                            Margin="0"
                                            ToolTip="Call"
                                            Click="CallContactButton_Click"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" x:Name="ConversationDetailGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition x:Name="ConversationDetailPrimaryRow" Height="*"/>
                                <RowDefinition x:Name="ConversationDetailHorizontalSplitterRow" Height="0"/>
                                <RowDefinition x:Name="ConversationDetailSecondaryRow" Height="0"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="ConversationMessagesColumn" Width="*" MinWidth="340"/>
                                <ColumnDefinition x:Name="ConversationVerticalSplitterColumn" Width="Auto"/>
                                <ColumnDefinition x:Name="ConversationCallHistoryColumn" Width="360" MinWidth="260" MaxWidth="480"/>
                            </Grid.ColumnDefinitions>

                            <Grid x:Name="ConversationMessagesPane" Grid.Row="0" Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Padding="14,6"
                                        Visibility="{Binding SelectedConversation,
                                            Converter={StaticResource NullToCollapsedConverter}}"
                                        BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1"
                                        Background="{DynamicResource BgMain}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="10"
                                                Background="{DynamicResource AccentBlueLight}" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding SelectedConversation.AvatarInitial}"
                                                       FontSize="14" FontWeight="Medium"
                                                       Foreground="{DynamicResource AccentBlue}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" MinWidth="150"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                                                <TextBox Text="{Binding SelectedConversation.DisplayName, Mode=OneWay}"
                                                         FontSize="16" FontWeight="Medium"
                                                         Foreground="{DynamicResource TextPrimary}"
                                                         IsReadOnly="True"
                                                         IsTabStop="False"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Padding="0"
                                                         FocusVisualStyle="{x:Null}"
                                                         HorizontalScrollBarVisibility="Hidden"
                                                         VerticalScrollBarVisibility="Disabled"/>
                                                <TextBox Text="{Binding SelectedConversation.FormattedPhone, Mode=OneWay}"
                                                         FontSize="11"
                                                         Foreground="{DynamicResource TextMuted}"
                                                         Margin="0,1,0,0"
                                                         IsReadOnly="True"
                                                         IsTabStop="False"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Padding="0"
                                                         FocusVisualStyle="{x:Null}"
                                                         HorizontalScrollBarVisibility="Hidden"
                                                         VerticalScrollBarVisibility="Disabled"/>
                                            </StackPanel>
                                            <Border Style="{StaticResource ThreadSearchBoxContainer}"
                                                    Grid.Row="0"
                                                    Grid.Column="2"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Center">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="&#xE8B6;" Style="{StaticResource MaterialIconText}" FontSize="14"
                                                               VerticalAlignment="Center" Margin="0,0,4,0"
                                                               Foreground="{DynamicResource TextMuted}"/>
                                                    <TextBox Grid.Column="1"
                                                             AutomationProperties.Name="Search this conversation"
                                                             AutomationProperties.AutomationId="ThreadSearchBox"
                                                             Text="{Binding ConversationSearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{StaticResource ThreadSearchTextBox}"/>
                                                    <TextBlock Grid.Column="2"
                                                               Text="{Binding ConversationSearchStatus}"
                                                               Style="{StaticResource ThreadSearchStatusText}"/>
                                                    <Button Grid.Column="3" Content="&#xE316;"
                                                            Style="{StaticResource ThreadSearchGlyphButton}"
                                                            Command="{Binding ConversationSearchPreviousCommand}"
                                                            ToolTip="Previous match"/>
                                                    <Button Grid.Column="4" Content="&#xE313;"
                                                            Style="{StaticResource ThreadSearchGlyphButton}"
                                                            Command="{Binding ConversationSearchNextCommand}"
                                                            ToolTip="Next match"/>
                                                    <Button Grid.Column="5" Content="&#xE5CD;"
                                                            Style="{StaticResource ThreadSearchGlyphButton}"
                                                            Command="{Binding ClearConversationSearchCommand}"
                                                            ToolTip="Clear search"/>
                                                </Grid>
                                            </Border>
                                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="Pinned"
                                                           FontSize="11"
                                                           FontWeight="Medium"
                                                           Foreground="{DynamicResource AccentBlue}"
                                                           Margin="0,0,10,0"
                                                           Visibility="{Binding IsSelectedConversationPinned,
                                                               Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <TextBlock Text="Alerts off"
                                                           FontSize="11"
                                                           FontWeight="Medium"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           Margin="0,0,10,0"
                                                           Visibility="{Binding AreSelectedConversationAlertsMuted,
                                                               Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <TextBlock Text="{Binding SelectedConversationPinnedSummary}"
                                                           FontSize="11"
                                                           FontWeight="Medium"
                                                           Foreground="{DynamicResource AccentBlue}"
                                                           Margin="0,0,10,0"
                                                           Visibility="{Binding HasSelectedConversationPinnedMessages,
                                                               Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <TextBlock Text="Blocked"
                                                           FontSize="11"
                                                           FontWeight="Medium"
                                                           Foreground="{DynamicResource AccentRed}"
                                                           Visibility="{Binding IsSelectedConversationBlocked,
                                                               Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </Grid>
                                        <WrapPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="12,0,0,0">
                                            <Button Content="&#xE14B;"
                                                    Style="{StaticResource CompactIconButton}"
                                                    Command="{Binding ToggleConversationBlockedCommand}"
                                                    ToolTip="{Binding SelectedConversationBlockTooltip}"/>
                                            <Button Content="&#xF10D;"
                                                    Style="{StaticResource CompactIconButton}"
                                                    Command="{Binding ToggleConversationPinnedCommand}"
                                                    ToolTip="{Binding SelectedConversationPinTooltip}"/>
                                            <Button Content="&#xE7F6;"
                                                    Style="{StaticResource CompactIconButton}"
                                                    Command="{Binding ToggleConversationAlertsMutedCommand}"
                                                    ToolTip="{Binding SelectedConversationAlertsTooltip}"/>
                                            <Button Content="&#xE151;"
                                                    Style="{StaticResource CompactIconButton}"
                                                    Command="{Binding MarkConversationReadCommand}"
                                                    ToolTip="Mark read"
                                                    Visibility="{Binding CanMarkSelectedConversationRead, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <Button Content="&#xF18A;"
                                                    Style="{StaticResource CompactIconButton}"
                                                    Command="{Binding MarkConversationUnreadCommand}"
                                                    ToolTip="Mark unread"
                                                    Visibility="{Binding CanMarkSelectedConversationUnread, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <Button Content="&#xE7FE;"
                                                    Style="{StaticResource CompactIconButton}"
                                                    Command="{Binding SaveAsContactCommand}"
                                                    CommandParameter="{Binding SelectedConversation.PhoneNumber}"
                                                    ToolTip="Add contact"
                                                    Visibility="{Binding CanAddSelectedConversationContact, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <Button Content="&#xE3C9;"
                                                    Style="{StaticResource CompactIconButton}"
                                                    Command="{Binding EditContactCommand}"
                                                    CommandParameter="{Binding SelectedConversationMatchingContact}"
                                                    ToolTip="Edit contact"
                                                    Visibility="{Binding CanEditSelectedConversationContact, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            <Button Content="&#xE0B0;"
                                                    Style="{StaticResource CompactIconButton}"
                                                    Margin="0"
                                                    ToolTip="Call"
                                                    Click="CallContactButton_Click"/>
                                        </WrapPanel>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Row="1"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedConversation}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Border Width="72" Height="72" CornerRadius="18"
                                            Background="{DynamicResource BgHover}"
                                            HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <TextBlock Text="&#xE0CA;" Style="{StaticResource MaterialIconText}" FontSize="36" Foreground="{DynamicResource Border}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Select a conversation"
                                               FontSize="16" FontWeight="Medium"
                                               Foreground="{DynamicResource TextMuted}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="or start a new one"
                                               FontSize="14" Foreground="{DynamicResource TextDisabled}"
                                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>

                                <!-- Copied toast  -  appears briefly after single-click copy -->
                                <Border Grid.Row="1"
                                        HorizontalAlignment="Center" VerticalAlignment="Top"
                                        Margin="0,8,0,0" Padding="14,6" CornerRadius="10" Panel.ZIndex="10"
                                        Background="{DynamicResource AccentBlue}"
                                        Visibility="{Binding CopiedToast,
                                            Converter={StaticResource NullOrEmptyToCollapsedConverter}}">
                                    <TextBlock Text="{Binding CopiedToast}"
                                               Foreground="White" FontSize="14" FontWeight="Medium"/>
                                </Border>

                                <Border Grid.Row="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,16,16,0"
                                        Padding="8"
                                        Panel.ZIndex="20"
                                        Background="{DynamicResource SurfaceContainerLow}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Visibility="{Binding HasHiddenMessageSurfacePanes, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Show threads"
                                                Style="{StaticResource TonalButton}"
                                                Height="32"
                                                Padding="14,0"
                                                Margin="0,0,8,0"
                                                Command="{Binding OpenMessagesListPaneCommand}"
                                                Visibility="{Binding ShowMessagesListPane, Converter={StaticResource InverseBoolConverter}}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Bubble list + scroll-to-bottom FAB -->
                                <Grid Grid.Row="1"
                                      Visibility="{Binding SelectedConversation,
                                          Converter={StaticResource NullToCollapsedConverter}}">
                                <ListBox x:Name="MessageList"
                                        ItemsSource="{Binding SelectedConversation.Messages}"
                                         Background="{DynamicResource BgSidebar}"
                                         BorderThickness="0"
                                         Padding="24,12,24,84"
                                         ItemContainerStyle="{StaticResource MessageListBoxItemStyle}"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.PanningMode="VerticalFirst"
                                         ScrollViewer.PanningDeceleration="0.0012"
                                         ScrollViewer.CanContentScroll="True"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="{Binding BubbleMargin}"
                                                    MouseLeftButtonUp="BubbleTap_Click"
                                                    Cursor="Hand">
                                            <!-- Date Divider -->
                                            <TextBlock Text="{Binding DateDividerText}"
                                                       FontSize="12" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,16,0,16">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowDateDivider}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Bubbles -->
                                            <Grid>
                                                <!-- Received bubble (left) -->
                                                <Border x:Name="bubbleIn"
                                                        HorizontalAlignment="Left"
                                                        MaxWidth="{Binding ActualWidth, ElementName=ConversationMessagesPane, Converter={StaticResource BubbleWidthConverter}}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource BubbleIn}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BubbleInBorder}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="CornerRadius" Value="{Binding BubbleRadius}"/>
                                                            <Setter Property="Padding" Value="12,8"/>
                                                            <Setter Property="Effect">
