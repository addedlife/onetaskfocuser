                                                            <Button Content="&#xE154;"
                                                                    Style="{StaticResource BubbleActionButtonStyle}"
                                                                    ToolTip="Forward"
                                                                    Click="BubbleActionForwardButton_Click"/>
                                                            <Button Content="&#xE0B0;"
                                                                    Style="{StaticResource BubbleActionButtonStyle}"
                                                                    ToolTip="Call"
                                                                    Click="BubbleActionCallButton_Click"/>
                                                            <Button Content="&#xE872;"
                                                                    Style="{StaticResource BubbleActionButtonStyle}"
                                                                    ToolTip="Delete"
                                                                    Click="BubbleActionDeleteButton_Click"/>
                                                            <Button Content="&#xF10D;"
                                                                    Style="{StaticResource BubbleActionPinButtonStyle}"
                                                                    ToolTip="{Binding PinActionLabel}"
                                                                    Click="BubbleActionPinButton_Click"/>
                                                        </UniformGrid>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                            </Grid>
                                        </StackPanel>
                                        <DataTemplate.Triggers>
