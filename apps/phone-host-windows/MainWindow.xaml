                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Padding="22,18,18,14"
                                            BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Phone"
                                                           FontSize="18" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                 <TextBlock Text="Recent calls stay visible."
                                                            FontSize="12"
                                                            Foreground="{DynamicResource TextMuted}"
                                                            Margin="0,4,0,0"
                                                            TextWrapping="Wrap"/>
                                                 <UniformGrid Columns="4" Margin="0,10,0,0" MaxWidth="290" HorizontalAlignment="Left">
                                                     <Button Content="All" Command="{Binding SetCallHistoryFilterCommand}" CommandParameter="All" Margin="0,0,5,0">
                                                         <Button.Style>
                                                             <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                                 <Setter Property="Height" Value="32"/>
                                                                 <Setter Property="Padding" Value="6,0"/>
                                                                 <Setter Property="FontSize" Value="11"/>
                                                                 <Setter Property="MinWidth" Value="0"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding IsCallHistoryFilterAll}" Value="True">
                                                                         <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                                         <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </Button.Style>
                                                     </Button>
                                                    <Button Command="{Binding SetCallHistoryFilterCommand}" CommandParameter="Missed" Margin="0,0,5,0">
                                                        <Grid>
                                                            <TextBlock Text="Missed" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding HasMissedCallAlert}" Value="True">
                                                                                <Setter Property="FontWeight" Value="Medium"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <Border Width="8"
                                                                    Height="8"
                                                                    CornerRadius="4"
                                                                    Background="{DynamicResource AccentRed}"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Margin="0,-3,-4,0"
                                                                    Visibility="{Binding HasMissedCallAlert, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        </Grid>
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                                <Setter Property="Height" Value="32"/>
                                                                 <Setter Property="Padding" Value="6,0"/>
                                                                 <Setter Property="FontSize" Value="11"/>
                                                                 <Setter Property="MinWidth" Value="0"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding IsCallHistoryFilterMissed}" Value="True">
                                                                         <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                                         <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </Button.Style>
                                                     </Button>
                                                     <Button Content="In" Command="{Binding SetCallHistoryFilterCommand}" CommandParameter="Incoming" Margin="0,0,5,0">
                                                         <Button.Style>
                                                             <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                                 <Setter Property="Height" Value="32"/>
                                                                 <Setter Property="Padding" Value="6,0"/>
                                                                 <Setter Property="FontSize" Value="11"/>
                                                                 <Setter Property="MinWidth" Value="0"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding IsCallHistoryFilterIncoming}" Value="True">
                                                                         <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                                         <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </Button.Style>
                                                     </Button>
                                                     <Button Content="Out" Command="{Binding SetCallHistoryFilterCommand}" CommandParameter="Outgoing">
                                                         <Button.Style>
                                                             <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                                 <Setter Property="Height" Value="32"/>
                                                                 <Setter Property="Padding" Value="6,0"/>
                                                                 <Setter Property="FontSize" Value="11"/>
                                                                 <Setter Property="MinWidth" Value="0"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding IsCallHistoryFilterOutgoing}" Value="True">
                                                                         <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                                         <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </Button.Style>
                                                     </Button>
                                                 </UniformGrid>
                                                 <StackPanel Orientation="Horizontal"
                                                             HorizontalAlignment="Center"
                                                             Margin="0,10,0,0">
                                                     <Button AutomationProperties.Name="Show keypad"
                                                             AutomationProperties.AutomationId="ConversationShowKeypadButton"
                                                             Command="{Binding ToggleConversationDialerPaneCommand}"
                                                             ToolTip="Show keypad"
                                                             Style="{StaticResource TonalButton}"
                                                             Height="34"
                                                             Padding="16,0"
                                                             Margin="0,0,8,0">
                                                         <StackPanel Orientation="Horizontal">
                                                             <TextBlock Text="&#xE0BC;"
                                                                        Style="{StaticResource MaterialIconText}"
                                                                        FontSize="18"
                                                                        Margin="0,0,6,0"/>
                                                             <TextBlock Text="Keypad"
                                                                        FontSize="12"
                                                                        FontWeight="Medium"
                                                                        VerticalAlignment="Center"/>
                                                         </StackPanel>
                                                     </Button>
                                                     <Button AutomationProperties.Name="Delete all call history"
                                                             AutomationProperties.AutomationId="ConversationDeleteAllCallHistoryButton"
                                                             Content="&#xE872;"
                                                             Command="{Binding DeleteAllCallHistoryCommand}"
                                                             ToolTip="Delete all call history">
                                                         <Button.Style>
                                                             <Style TargetType="Button" BasedOn="{StaticResource CompactIconButton}">
                                                                 <Setter Property="Visibility" Value="Visible"/>
                                                                 <Style.Triggers>
                                                                     <DataTrigger Binding="{Binding CallHistory.Count}" Value="0">
                                                                         <Setter Property="Visibility" Value="Collapsed"/>
                                                                     </DataTrigger>
                                                                 </Style.Triggers>
                                                             </Style>
                                                         </Button.Style>
                                                     </Button>
                                                 </StackPanel>
                                                 <Border Background="{DynamicResource SurfaceContainerLow}"
                                                        BorderBrush="{DynamicResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="10,7"
                                                        Margin="0,10,0,0"
                                                        Visibility="{Binding HasUndoCallHistoryDelete, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding UndoCallHistoryDeleteText}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextSecond}"
                                                                   VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <Button Grid.Column="1"
                                                                Content="Undo"
                                                                Style="{StaticResource TonalButton}"
                                                                Height="28"
                                                                Padding="12,0"
                                                                Margin="10,0,0,0"
                                                                Command="{Binding UndoCallHistoryDeleteCommand}"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1"
                                            Padding="18,14,18,14"
                                            BorderBrush="{DynamicResource Border}"
                                            BorderThickness="0,0,0,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSelectedConversationPinnedMessages}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="Pinned Messages"
                                                       FontSize="16"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="Pinned notes from this thread stay one click away."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       Margin="0,4,0,0"/>
                                            <ScrollViewer Margin="0,12,0,0"
                                                          MaxHeight="180"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding SelectedConversationPinnedMessages}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Style="{StaticResource SuggestionRowButton}"
                                                                    Padding="12,10"
                                                                    Margin="0,0,0,8"
                                                                    Click="PinnedMessageEntry_Click">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="&#xF10D;"
                                                                               Style="{StaticResource MaterialIconText}"
                                                                               FontSize="16"
                                                                               Foreground="{DynamicResource AccentBlue}"
                                                                               Margin="0,1,10,0"
                                                                               VerticalAlignment="Top"/>
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="{Binding PreviewBody}"
                                                                                   FontSize="14"
                                                                                   FontWeight="Medium"
                                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                                   TextWrapping="Wrap"
                                                                                   LineHeight="18"
                                                                                   MaxHeight="36"/>
                                                                        <TextBlock Text="{Binding TimestampDisplay}"
                                                                                   FontSize="11"
                                                                                   Foreground="{DynamicResource TextMuted}"
                                                                                   Margin="0,4,0,0"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="You"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource TextMuted}"
                                                                               Margin="10,1,0,0"
                                                                               VerticalAlignment="Top">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsSent}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>

                                    <Grid Grid.Row="2">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasFilteredCallHistory}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="&#xE0B0;" Style="{StaticResource MaterialIconText}" FontSize="42" Foreground="{DynamicResource Border}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                            <TextBlock Text="No call history yet"
                                                       FontSize="14" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>

                                        <ListBox ItemsSource="{Binding FilteredCallHistory}"
                                                 SelectedItem="{Binding SelectedCallRecord}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 MouseDoubleClick="CallHistoryList_MouseDoubleClick"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="18,20"/>
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource BgSelected}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding DirectionIcon}"
                                                                   FontFamily="{StaticResource MaterialIconsRoundFont}"
                                                                   FontSize="18"
                                                                   Foreground="{DynamicResource TextMuted}"
                                                                   VerticalAlignment="Top"
                                                                   Margin="0,1,14,0"/>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding DisplayNumber}"
                                                                       FontSize="18"
                                                                       FontWeight="Medium"
                                                                       Foreground="{DynamicResource TextPrimary}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding DisplayNumber}"/>
                                                            <TextBlock Text="{Binding SubtitleDisplay}"
                                                                       FontSize="14"
                                                                       Foreground="{DynamicResource TextMuted}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding TimeDisplay}"
                                                                   FontSize="12"
                                                                   Foreground="{DynamicResource TextMuted}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="12,1,0,0"/>
                                                        <Border Grid.Column="0"
                                                                Grid.ColumnSpan="3"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Center"
                                                                Background="{DynamicResource BgSelected}"
                                                                BorderBrush="{DynamicResource Border}"
                                                                BorderThickness="1"
                                                                CornerRadius="16"
                                                                Padding="4">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Button Content="&#xE625;"
                                                                        Style="{StaticResource CallRowActionButtonStyle}"
                                                                        ToolTip="Message this number"
                                                                        Tag="{Binding Number}"
                                                                        Click="CallHistoryMessageButton_Click"/>
                                                                <Button Content="&#xE0B0;"
                                                                        Style="{StaticResource CallRowActionButtonStyle}"
                                                                        ToolTip="Call this number"
                                                                        Tag="{Binding Number}"
                                                                        Click="CallHistoryCallButton_Click"/>
                                                                <Button Content="&#xE14B;"
                                                                        Style="{StaticResource CallRowActionButtonStyle}"
                                                                        ToolTip="Block / unblock locally"
                                                                        Command="{Binding DataContext.ToggleCallRecordBlockedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"/>
                                                                <Button Content="&#xE872;"
                                                                        Style="{StaticResource CallRowActionButtonStyle}"
                                                                        ToolTip="Delete call entry"
                                                                        Command="{Binding DataContext.DeleteCallRecordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>

                                    <Border Grid.Row="3"
                                            Padding="18,14,18,18"
                                            BorderBrush="{DynamicResource Border}"
                                            BorderThickness="0,1,0,0"
                                            Visibility="{Binding ShowConversationDialerPane, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="Keypad"
                                                           FontSize="16"
                                                           FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Content="&#xE5CD;"
                                                        Style="{StaticResource CompactIconButton}"
                                                        Margin="8,0,0,0"
                                                        Command="{Binding CloseConversationDialerPaneCommand}"
                                                        ToolTip="Hide keypad"/>
                                            </Grid>

                                             <Grid Margin="0,0,0,12" MinHeight="44">
                                                 <Grid.ColumnDefinitions>
                                                     <ColumnDefinition Width="*"/>
                                                     <ColumnDefinition Width="Auto"/>
                                                 </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding DialNumber, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="22"
                                                         FontWeight="Normal"
                                                         TextAlignment="Center"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         Padding="8"
                                                         VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Content="&#xE14A;"
                                                        FontFamily="{StaticResource MaterialIconsRoundFont}"
                                                        Foreground="{DynamicResource TextMuted}"
                                                        FontSize="18"
                                                        Padding="10"
                                                         Background="Transparent"
                                                         Click="BackspaceButton_Click"/>
                                             </Grid>

                                             <Border Style="{StaticResource SuggestionListBorderStyle}"
                                                     Margin="0,0,0,12"
                                                     Visibility="{Binding ShowCallContactSuggestions, Converter={StaticResource BoolToVisibilityConverter}}">
                                                 <ListBox ItemsSource="{Binding CallContacts}"
                                                          Style="{StaticResource SuggestionListBoxStyle}"
                                                          ItemContainerStyle="{StaticResource SuggestionListItemStyle}"
                                                          MaxHeight="156">
                                                     <ListBox.ItemTemplate>
                                                         <DataTemplate>
                                                             <Border Background="Transparent"
                                                                     CornerRadius="10"
                                                                     Padding="10,9">
                                                                 <Grid>
                                                                     <Grid.ColumnDefinitions>
                                                                         <ColumnDefinition Width="*"/>
                                                                         <ColumnDefinition Width="Auto"/>
                                                                         <ColumnDefinition Width="Auto"/>
                                                                     </Grid.ColumnDefinitions>
                                                                     <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                                         <TextBlock Text="{Binding DisplayName}"
                                                                                    FontSize="14"
                                                                                    FontWeight="Medium"
                                                                                    TextTrimming="CharacterEllipsis"/>
                                                                         <TextBlock Text="{Binding FormattedPhone}"
                                                                                    FontSize="11"
                                                                                    Foreground="{DynamicResource TextMuted}"
                                                                                    Margin="0,2,0,0"/>
                                                                     </StackPanel>
                                                                     <Button Grid.Column="1"
                                                                             Content="Text"
                                                                             Style="{StaticResource TonalButton}"
                                                                             Height="30"
                                                                             Padding="10,0"
                                                                             Margin="0,0,6,0"
                                                                             Click="ContactManagerTextButton_Click"/>
                                                                     <Button Grid.Column="2"
                                                                             Content="Call"
                                                                             Style="{StaticResource PrimaryButton}"
                                                                             Height="30"
                                                                             Padding="10,0"
                                                                             Click="ContactManagerCallButton_Click"/>
                                                                 </Grid>
                                                             </Border>
                                                         </DataTemplate>
                                                     </ListBox.ItemTemplate>
                                                 </ListBox>
                                             </Border>

                                             <UniformGrid Columns="3" Rows="4" Margin="0,0,0,12">
                                                 <Button Content="1" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="1"/>
                                                <Button Content="2" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="2"/>
                                                <Button Content="3" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="3"/>
                                                <Button Content="4" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="4"/>
                                                <Button Content="5" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="5"/>
                                                <Button Content="6" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="6"/>
                                                <Button Content="7" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="7"/>
                                                <Button Content="8" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="8"/>
                                                <Button Content="9" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="9"/>
                                                <Button Content="*" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="*"/>
                                                <Button Content="0" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="0"/>
                                                <Button Content="#" Style="{StaticResource DialKey}" Width="52" Height="52" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="#"/>
                                            </UniformGrid>

                                            <Button Command="{Binding DialVoicemailCommand}"
                                                    Style="{StaticResource TonalButton}"
                                                    Height="40"
                                                    Margin="0,0,0,8"
                                                    HorizontalAlignment="Stretch">
                                                <Grid HorizontalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Grid Margin="0,0,8,0">
                                                            <TextBlock Text="&#xE0D2;"
                                                                       Style="{StaticResource MaterialIconText}"
                                                                       FontSize="20"/>
                                                            <Ellipse Width="8"
                                                                     Height="8"
                                                                     Fill="{DynamicResource AccentRed}"
                                                                     HorizontalAlignment="Right"
                                                                     VerticalAlignment="Top"
                                                                     Visibility="{Binding HasVoicemailAlert, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        </Grid>
                                                        <TextBlock Text="Voicemail"
                                                                   FontSize="14"
                                                                   FontWeight="Medium"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Button>

                                            <Button Command="{Binding DialCommand}"
                                                    Style="{StaticResource SuccessButton}"
                                                    Height="44"
                                                    HorizontalAlignment="Stretch">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Text="&#xE0B0;"
                                                               Style="{StaticResource MaterialIconText}"
                                                               FontSize="22"
                                                               Foreground="White"
                                                               Margin="0,0,8,0"/>
                                                    <TextBlock Text="Call"
                                                               FontSize="14"
                                                               FontWeight="Medium"
                                                               Foreground="White"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                    </Grid>

                    <!-- New message compose pane (overlaps thread view) -->
                    <Grid x:Name="ComposeNewPanel"
                          Visibility="{Binding ShowComposePanel,
                              Converter={StaticResource BoolToVisibilityConverter}}"
                          Background="{DynamicResource BgMain}"
                          HorizontalAlignment="Left"
                          Width="{Binding ActualWidth, ElementName=ConversationMessagesPane}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="24,14"
                                BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Cancel"
                                        Style="{StaticResource TonalButton}"
                                        Height="36" Padding="16,0" Margin="0,0,16,0"
                                        Click="CloseComposeButton_Click"/>
                                <TextBlock Grid.Column="1" Text="New Message"
                                           FontSize="16" FontWeight="Medium"
                                           Foreground="{DynamicResource TextPrimary}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="40,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                <TextBlock Text="TO" Style="{StaticResource SectionLabel}" Margin="4,0,0,8"/>
                                <TextBox x:Name="ComposeRecipientTextBox"
                                         Text="{Binding ComposeRecipientInput, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="New message recipient search"
                                         AutomationProperties.AutomationId="ComposeRecipientTextBox"
                                         FontSize="18"/>
                                <Border Style="{StaticResource SuggestionListBorderStyle}"
                                        Visibility="{Binding ShowComposeContactSuggestions, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListBox ItemsSource="{Binding ComposeContacts}"
                                             Style="{StaticResource SuggestionListBoxStyle}"
                                             ItemContainerStyle="{StaticResource SuggestionListItemStyle}"
                                             MaxHeight="220">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Button Style="{StaticResource SuggestionRowButton}"
                                                        Command="{Binding DataContext.PickComposeContactCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Click="ComposeContactSuggestion_Click">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Medium"/>
                                                        <TextBlock Text="{Binding FormattedPhone}" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                                <Border Background="{DynamicResource BgHover}" CornerRadius="12" Padding="12,10" Margin="0,10,0,0"
                                        Visibility="{Binding HasSelectedComposeContact, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedComposeContactName}" FontSize="14" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimary}"/>
                                        <TextBlock Text="{Binding SelectedComposeContactPhone}" FontSize="12"
                                                   Foreground="{DynamicResource TextMuted}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Save as contact"
                                            Style="{StaticResource TonalButton}"
                                            Padding="16,0" Margin="0,0,12,0"
                                            Command="{Binding SaveAsContactCommand}"
                                            CommandParameter="{Binding ComposeContactActionNumber}"
                                            Visibility="{Binding CanSaveComposeContact, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    <Button Content="Edit contact"
                                            Style="{StaticResource TonalButton}"
                                            Padding="16,0"
                                            Command="{Binding EditContactCommand}"
                                            CommandParameter="{Binding ComposeMatchingContact}"
                                            Visibility="{Binding CanEditComposeContact, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,0,24">
                                <TextBlock Text="MESSAGE" Style="{StaticResource SectionLabel}" Margin="4,0,0,8"/>
                                <TextBox x:Name="ComposeNewBodyBox"
                                         Text="{Binding ComposeBody, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="18"
                                         MinHeight="160"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         PreviewKeyDown="ComposeBox_KeyDown"/>
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Width="48"
                                        Height="48"
                                        Padding="0"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource TonalButton}"
                                        Command="{Binding AddComposeAttachmentCommand}"
                                        ToolTip="Attach pictures, files, or contact cards. DeskPhone will send them as MMS when the phone accepts Bluetooth MAP media sending.">
                                    <TextBlock Text="&#xE226;"
                                               Style="{StaticResource MaterialIconText}"
                                               FontSize="23"/>
                                </Button>
                                <Button Grid.Column="1" Content="Send Message"
                                        Style="{StaticResource PrimaryButton}"
                                        FontSize="16" FontWeight="Medium" Height="48"
                                        Command="{Binding SendMessageCommand}"/>
                            </Grid>
                            <ItemsControl Grid.Row="2" Grid.ColumnSpan="2" ItemsSource="{Binding ComposeAttachments}" Margin="0,58,0,0"
                                          Visibility="{Binding HasComposeAttachments, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BgHover}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="10" Padding="8,4" Margin="0,0,6,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="12" Foreground="{DynamicResource TextPrimary}" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
                                                <Button Content="&#xE5CD;" FontFamily="{StaticResource MaterialIconsRoundFont}" FontSize="14" Width="22" Height="22" Margin="6,0,0,0" Padding="0" Style="{StaticResource CompactIconButton}"
                                                        Command="{Binding DataContext.RemoveComposeAttachmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding ComposeAttachmentNotice}" FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" Margin="0,90,0,0"
                                       Visibility="{Binding HasComposeAttachments, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ================================================================ -->
            <!-- TAB: CALLS                                                   -->
            <!-- ================================================================ -->
            <Grid Grid.Row="3" x:Name="CallsRootGrid">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=TabCalls}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="CallsPrimaryRow" Height="*"/>
                    <RowDefinition x:Name="CallsHorizontalSplitterRow" Height="0"/>
                    <RowDefinition x:Name="CallsSecondaryRow" Height="0"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="CallsListColumn" Width="*"/>
                    <ColumnDefinition x:Name="CallsVerticalSplitterColumn" Width="Auto"/>
                    <ColumnDefinition x:Name="DialerColumn" Width="380" MinWidth="280" MaxWidth="520"/>
                </Grid.ColumnDefinitions>

                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,16,16,0"
                        Padding="8"
                        Panel.ZIndex="20"
                        Background="{DynamicResource BgMain}"
                        BorderBrush="{DynamicResource Border}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Visibility="{Binding HasHiddenCallSurfacePanes, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Show recents"
                                Style="{StaticResource TonalButton}"
                                Height="32"
                                Padding="14,0"
                                Margin="0,0,8,0"
                                Command="{Binding OpenRecentCallsPaneCommand}"
                                Visibility="{Binding ShowRecentCallsPane, Converter={StaticResource InverseBoolConverter}}"/>
                        <Button Content="Show dialer"
                                Style="{StaticResource TonalButton}"
                                Height="32"
                                Padding="14,0"
                                Command="{Binding OpenDialerPaneCommand}"
                                Visibility="{Binding ShowDialerPane, Converter={StaticResource InverseBoolConverter}}"/>
                    </StackPanel>
                </Border>

                <!-- Recent calls list -->
                <Border x:Name="RecentCallsPane"
                        Grid.Row="0"
                        Grid.Column="0"
                        Background="{DynamicResource BgMain}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="28,20,20,14">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="Recents"
                                               FontSize="22" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <Button Grid.Column="1"
                                            Content="&#xE872;"
                                            Margin="0,0,10,0"
                                            Command="{Binding DeleteAllCallHistoryCommand}"
                                            ToolTip="Delete all call history">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource CompactIconButton}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CallHistory.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Content="&#xE5CD;"
                                            Style="{StaticResource CompactIconButton}"
                                            Margin="8,0,0,0"
                                            Command="{Binding CloseRecentCallsPaneCommand}"
                                            ToolTip="Hide recents"/>
                                </Grid>

                                <TextBlock Text="Single-click a row to reveal message and call actions. Double-click a row to place the call immediately."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMuted}"
                                           Margin="0,12,0,0"
                                           TextWrapping="Wrap"/>
                                <UniformGrid Columns="4" Margin="0,12,0,0">
                                    <Button Content="All" Command="{Binding SetCallHistoryFilterCommand}" CommandParameter="All" Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                <Setter Property="Height" Value="32"/>
                                                <Setter Property="Padding" Value="8,0"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCallHistoryFilterAll}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Command="{Binding SetCallHistoryFilterCommand}" CommandParameter="Missed" Margin="0,0,6,0">
                                        <Grid>
                                            <TextBlock Text="Missed" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasMissedCallAlert}" Value="True">
                                                                <Setter Property="FontWeight" Value="Medium"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Border Width="8"
                                                    Height="8"
                                                    CornerRadius="4"
                                                    Background="{DynamicResource AccentRed}"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,-3,-4,0"
                                                    Visibility="{Binding HasMissedCallAlert, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </Grid>
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                <Setter Property="Height" Value="32"/>
                                                <Setter Property="Padding" Value="8,0"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCallHistoryFilterMissed}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Incoming" Command="{Binding SetCallHistoryFilterCommand}" CommandParameter="Incoming" Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                <Setter Property="Height" Value="32"/>
                                                <Setter Property="Padding" Value="8,0"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCallHistoryFilterIncoming}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Outgoing" Command="{Binding SetCallHistoryFilterCommand}" CommandParameter="Outgoing">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                                <Setter Property="Height" Value="32"/>
                                                <Setter Property="Padding" Value="8,0"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCallHistoryFilterOutgoing}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBlueLight}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </UniformGrid>
                                <Border Background="{DynamicResource SurfaceContainerLow}"
                                        BorderBrush="{DynamicResource Border}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,8"
                                        Margin="0,12,0,0"
                                        Visibility="{Binding HasUndoCallHistoryDelete, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding UndoCallHistoryDeleteText}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecond}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1"
                                                Content="Undo"
                                                Style="{StaticResource TonalButton}"
                                                Height="28"
                                                Padding="12,0"
                                                Margin="10,0,0,0"
                                                Command="{Binding UndoCallHistoryDeleteCommand}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="1"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasFilteredCallHistory}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="&#xE0B0;" Style="{StaticResource MaterialIconText}" FontSize="48" Foreground="{DynamicResource Border}"
                                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="No recent calls"
                                       FontSize="16" FontWeight="Medium"
                                       Foreground="{DynamicResource TextMuted}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding FilteredCallHistory}"
                                 SelectedItem="{Binding SelectedCallRecord}"
                                 Background="Transparent" BorderThickness="0"
                                 MouseDoubleClick="CallHistoryList_MouseDoubleClick"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding"         Value="24,12"/>
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush"     Value="{DynamicResource Border}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BgHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource BgSelected}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayNumber}"
                                                       FontSize="16" FontWeight="Medium">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Direction}" Value="Missed">
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentRed}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding SubtitleDisplay}"
                                                       FontSize="14" Foreground="{DynamicResource TextMuted}"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding TimeDisplay}"
                                                   FontSize="14" Foreground="{DynamicResource TextMuted}"
                                                   VerticalAlignment="Center"/>
                                        <Border Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource BgSelected}"
                                                BorderBrush="{DynamicResource Border}"
                                                BorderThickness="1"
                                                CornerRadius="16"
                                                Padding="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="&#xE625;"
                                                        Style="{StaticResource CallRowActionButtonStyle}"
                                                        ToolTip="Message this number"
                                                        Tag="{Binding Number}"
                                                        Click="CallHistoryMessageButton_Click"/>
                                                <Button Content="&#xE0B0;"
                                                        Style="{StaticResource CallRowActionButtonStyle}"
                                                        ToolTip="Call this number"
                                                        Tag="{Binding Number}"
                                                        Click="CallHistoryCallButton_Click"/>
                                                <Button Content="&#xE14B;"
                                                        Style="{StaticResource CallRowActionButtonStyle}"
                                                        ToolTip="Block / unblock locally"
                                                        Command="{Binding DataContext.ToggleCallRecordBlockedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="&#xE872;"
                                                        Style="{StaticResource CallRowActionButtonStyle}"
                                                        VerticalAlignment="Center"
                                                        ToolTip="Delete call entry"
                                                        Command="{Binding DataContext.DeleteCallRecordCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <GridSplitter x:Name="CallsVerticalSplitter"
                              Grid.Row="0"
                              Grid.Column="1"
                              Style="{StaticResource MacSplitter}"/>

                <GridSplitter x:Name="CallsHorizontalSplitter"
                              Grid.Row="1"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              Style="{StaticResource HorizontalMacSplitter}"
                              Visibility="Collapsed"/>

                <!-- Dial pad -->
                <Border x:Name="DialerPane"
                        Grid.Row="0"
                        Grid.Column="2"
                        Background="{DynamicResource BgMain}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Grid MaxWidth="356" HorizontalAlignment="Center">
                    <StackPanel Margin="16,16,16,20">

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Dialer"
                                       FontSize="21"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <Button Grid.Column="1"
                                    Content="&#xE5CD;"
                                    Style="{StaticResource CompactIconButton}"
                                    Margin="8,0,0,0"
                                    Command="{Binding CloseDialerPaneCommand}"
                                    ToolTip="Hide dialer"/>
                        </Grid>

                        <Grid Margin="0,0,0,8" MinHeight="56">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="MainDialNumberBox"
                                     Grid.Column="0"
                                     AutomationProperties.Name="Dial number or contact"
                                     AutomationProperties.AutomationId="MainDialNumberBox"
                                     Text="{Binding DialNumber, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="24" FontWeight="Normal"
                                     TextAlignment="Left"
                                     BorderThickness="0" Background="Transparent"
                                     Padding="10" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="&#xE14A;"
                                    FontFamily="{StaticResource MaterialIconsRoundFont}"
                                    Foreground="{DynamicResource TextMuted}"
                                    FontSize="18" Padding="14,14" Background="Transparent"
                                    Click="BackspaceButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource TonalButton}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DialNumber.Length}" Value="0">
                                                <Setter Property="Visibility" Value="Hidden"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                        <TextBlock Text="Type a number or contact name, then press Call."
                                   FontSize="12"
                                   Foreground="{DynamicResource TextMuted}"
                                   Margin="4,0,0,12"/>

                        <StackPanel Margin="0,0,0,16">
                            <WrapPanel Margin="0,0,0,8" ItemHeight="36" ItemWidth="130">
                                <Button Content="Save as contact"
                                        Style="{StaticResource TonalButton}"
                                        Padding="16,0" Margin="0,0,10,10"
                                        Command="{Binding SaveAsContactCommand}"
                                        CommandParameter="{Binding DialNumber}"
                                        Visibility="{Binding CanSaveDialContact, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <Button Content="Edit contact"
                                        Style="{StaticResource TonalButton}"
                                        Padding="16,0"
                                        Margin="0,0,10,10"
                                        Command="{Binding EditContactCommand}"
                                        CommandParameter="{Binding DialMatchingContact}"
                                        Visibility="{Binding CanEditDialContact, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </WrapPanel>
                            <Border Style="{StaticResource SuggestionListBorderStyle}"
                                    Visibility="{Binding ShowCallContactSuggestions, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ListBox ItemsSource="{Binding CallContacts}"
                                         Style="{StaticResource SuggestionListBoxStyle}"
                                         ItemContainerStyle="{StaticResource SuggestionListItemStyle}"
                                         MaxHeight="200">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="Transparent"
                                                    CornerRadius="10"
                                                    Padding="14,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="Medium"/>
                                                        <TextBlock Text="{Binding FormattedPhone}" FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Content="Text"
                                                            Style="{StaticResource TonalButton}"
                                                            Height="34"
                                                            Padding="14,0"
                                                            Margin="0,0,8,0"
                                                            Click="ContactManagerTextButton_Click"/>
                                                    <Button Grid.Column="2"
                                                            Content="Call"
                                                            Style="{StaticResource PrimaryButton}"
                                                            Height="34"
                                                            Padding="14,0"
                                                            Click="ContactManagerCallButton_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </StackPanel>

                        <UniformGrid Columns="3" Rows="4" Margin="0,0,0,16">
                            <Button Content="1"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="1"/>
                            <Button Content="2"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="2"/>
                            <Button Content="3"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="3"/>
                            <Button Content="4"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="4"/>
                            <Button Content="5"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="5"/>
                            <Button Content="6"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="6"/>
                            <Button Content="7"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="7"/>
                            <Button Content="8"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="8"/>
                            <Button Content="9"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="9"/>
                            <Button Content="*"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="*"/>
                            <Button Content="0"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="0"/>
                            <Button Content="#"  Style="{StaticResource DialKey}" Width="60" Height="60" Margin="4" Command="{Binding DialPadCommand}" CommandParameter="#"/>
                        </UniformGrid>

                        <Button Command="{Binding DialVoicemailCommand}"
                                Style="{StaticResource TonalButton}"
                                Height="40"
                                Margin="0,0,0,12"
                                HorizontalAlignment="Stretch">
                            <Grid HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Grid Margin="0,0,8,0">
                                        <TextBlock Text="&#xE0D2;"
                                                   Style="{StaticResource MaterialIconText}"
                                                   FontSize="20"/>
                                        <Ellipse Width="8"
                                                 Height="8"
                                                 Fill="{DynamicResource AccentRed}"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Top"
                                                 Visibility="{Binding HasVoicemailAlert, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </Grid>
                                    <TextBlock Text="Voicemail"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- Large round call button -->
                        <Button Command="{Binding DialCommand}" HorizontalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SuccessButton}">
                                    <Setter Property="Width"    Value="60"/>
                                    <Setter Property="Height"   Value="60"/>
                                    <Setter Property="Padding"  Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="30" Width="60" Height="60">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.38"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentGreenDark}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="&#xE0B0;" Style="{StaticResource MaterialIconText}" FontSize="28" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ================================================================ -->
            <!-- TAB: CONTACTS                                                -->
            <!-- ================================================================ -->
            <Border Grid.Row="3" Padding="40,32" Background="{DynamicResource BgSidebar}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=TabContacts}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid MaxWidth="1160" HorizontalAlignment="Left">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Contacts"
                                       FontSize="28"
                                       FontWeight="Medium"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Search saved contacts, then call, text, edit, or add from one place instead of hopping through Settings."
                                       Margin="0,8,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextMuted}"
                                       TextWrapping="Wrap"
                                       LineHeight="22"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="New Contact"
                                Style="{StaticResource PrimaryButton}"
                                Padding="20,0"
                                Command="{Binding NewContactCommand}"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="SEARCH" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                                <TextBox Text="{Binding SettingsContactSearch, UpdateSourceTrigger=PropertyChanged}"
                                         Grid.Row="1"
                                         FontSize="14"
                                         Margin="0,0,0,12"/>
                                <ListBox ItemsSource="{Binding EditableContacts}"
                                         Grid.Row="2"
                                         SelectedItem="{Binding SelectedEditableContact}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MinHeight="0"
                                         ScrollViewer.CanContentScroll="True"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0,0,0,6"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="ContactListItemBorder"
                                                    Padding="14,12"
                                                    CornerRadius="14"
                                                    Background="{DynamicResource BgHover}"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="14"
                                                               FontWeight="Medium"
                                                               Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="{Binding PrimaryPhone}"
                                                               Margin="0,4,0,0"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextMuted}"/>
                                                    <TextBlock Text="{Binding PhoneNumbers.Count, StringFormat={}{0} saved number(s)}"
                                                               Margin="0,4,0,0"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextMuted}"/>
                                                </StackPanel>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter TargetName="ContactListItemBorder" Property="Background" Value="{DynamicResource BgMain}"/>
                                                    <Setter TargetName="ContactListItemBorder" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                    <Setter TargetName="ContactListItemBorder" Property="BorderBrush" Value="{DynamicResource Border}"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="2">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="CONTACT ACTIONS" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                                    <TextBlock Text="{Binding SelectedEditableContactDisplayName}"
                                               FontSize="20"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="Use a saved number below to text or call it directly, then edit the contact details underneath."
                                               Margin="0,8,0,0"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap"
                                               LineHeight="20"/>

                                    <ItemsControl ItemsSource="{Binding SelectedEditableContactOptions}"
                                                  Visibility="{Binding HasSelectedEditableContact, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource BgHover}"
                                                        CornerRadius="14"
                                                        Padding="14,12"
                                                        Margin="0,12,0,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding FormattedPhone}"
                                                                       FontSize="16"
                                                                       FontWeight="Medium"
                                                                       Foreground="{DynamicResource TextPrimary}"/>
                                                            <TextBlock Text="Saved number"
                                                                       Margin="0,4,0,0"
                                                                       FontSize="12"
                                                                       Foreground="{DynamicResource TextMuted}"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1"
                                                                Content="Text"
                                                                Style="{StaticResource TonalButton}"
                                                                Height="36"
                                                                Padding="16,0"
                                                                Margin="12,0,10,0"
                                                                Click="ContactManagerTextButton_Click"/>
                                                        <Button Grid.Column="2"
                                                                Content="Call"
                                                                Style="{StaticResource PrimaryButton}"
                                                                Height="36"
                                                                Padding="16,0"
                                                                Click="ContactManagerCallButton_Click"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Background="{DynamicResource BgHover}"
                                            CornerRadius="14"
                                            Padding="16"
                                            Margin="0,12,0,0"
                                            Visibility="{Binding HasSelectedEditableContact, Converter={StaticResource InverseBoolConverter}}">
                                        <TextBlock Text="Select a saved contact to light up its call and text actions here."
                                                   FontSize="14"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="20"/>
                                    </Border>

                                    <Button Content="Edit Details"
                                            Style="{StaticResource TonalButton}"
                                            Height="36"
                                            Padding="18,0"
                                            Margin="0,14,0,0"
                                            HorizontalAlignment="Left"
                                            Visibility="{Binding HasSelectedEditableContact, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Click="ContactManagerEditButton_Click"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="EDITOR" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                                    <TextBlock Text="{Binding ContactEditorTitle}"
                                               FontSize="18"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}"
                                               Margin="0,0,0,14"/>
                                    <TextBlock Text="NAME" Style="{StaticResource SectionLabel}" Margin="4,0,0,6"/>
                                    <TextBox x:Name="ContactManagerNameBox"
                                             Text="{Binding ContactEditorName, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14"
                                             Margin="0,0,0,12"/>
                                    <TextBlock Text="PHONE" Style="{StaticResource SectionLabel}" Margin="4,0,0,6"/>
                                    <TextBox Text="{Binding ContactEditorPhone, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="14"
                                             Margin="0,0,0,16"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="New"
                                                Style="{StaticResource TonalButton}"
                                                Padding="16,0"
                                                Margin="0,0,10,0"
                                                Command="{Binding NewContactCommand}"/>
                                        <Button Content="Delete"
                                                Style="{StaticResource DestructiveButton}"
                                                Padding="16,0"
                                                Margin="0,0,10,0"
                                                Command="{Binding DeleteContactCommand}"
                                                Visibility="{Binding CanDeleteSelectedContact, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <Button Content="Save Contact"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="18,0"
                                                Command="{Binding SaveContactCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ================================================================ -->
            <!-- TAB: SETTINGS                                                -->
            <!-- ================================================================ -->
            <ScrollViewer Grid.Row="3" Padding="40,32" Background="{DynamicResource BgSidebar}">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource TouchScrollViewerStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=TabSettings}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <Grid MaxWidth="1120" HorizontalAlignment="Left">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="SETTINGS" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                            <RadioButton GroupName="SettingsSections"
                                         Style="{StaticResource NavButton}"
                                         IsChecked="{Binding IsConnectionSettingsSectionSelected}">
                                <TextBlock Text="Connection"/>
                            </RadioButton>
                            <RadioButton GroupName="SettingsSections"
                                         Style="{StaticResource NavButton}"
                                         IsChecked="{Binding IsAppearanceSettingsSectionSelected}">
                                <TextBlock Text="Appearance"/>
                            </RadioButton>
                            <RadioButton GroupName="SettingsSections"
                                         Style="{StaticResource NavButton}"
                                         IsChecked="{Binding IsSyncSettingsSectionSelected}">
                                <TextBlock Text="Contact Sync"/>
                            </RadioButton>
                            <RadioButton GroupName="SettingsSections"
                                         Style="{StaticResource NavButton}"
                                         IsChecked="{Binding IsAudioSettingsSectionSelected}">
                                <TextBlock Text="Audio"/>
                            </RadioButton>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding SettingsSectionTitle}" FontSize="28" FontWeight="Medium"
                                   Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding SettingsSectionDescription}"
                                   FontSize="14" Foreground="{DynamicResource TextMuted}"
                                   TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,22"/>

                        <StackPanel Visibility="{Binding IsConnectionSettingsSectionSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="PRIMARY DEVICE" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                                    <Border Background="{DynamicResource BgHover}" CornerRadius="14" Padding="18" Margin="0,0,0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                <TextBlock Text="{Binding QuickConnectDeviceName}"
                                                           FontSize="16" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding QuickConnectDeviceSummary}"
                                                           FontSize="14" Foreground="{DynamicResource TextMuted}"
                                                           TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding QuickConnectDevice.Address}"
                                                           FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                           Visibility="{Binding HasQuickConnectDevice, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <Button Content="Connect"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Padding="22,0" Margin="0,0,0,10"
                                                        Command="{Binding ConnectQuickDeviceCommand}"
                                                        Visibility="{Binding HasQuickConnectDevice, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <Button Content="Scan for new device"
                                                        Style="{StaticResource TonalButton}"
                                                        Padding="18,0"
                                                        Command="{Binding ScanCommand}"
                                                        IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBoolConverter}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="SAVED DEVICES" Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding OtherKnownDevices}"
                                                  Visibility="{Binding HasOtherKnownDevices, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource BgHover}"
                                                        CornerRadius="12" Padding="16,10" Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontSize="14" FontWeight="Medium"
                                                                       Foreground="{DynamicResource TextPrimary}"/>
                                                            <TextBlock Text="{Binding Address}"
                                                                       FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                                       Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="Connect"
                                                                Style="{StaticResource TonalButton}"
                                                                Height="34" Padding="16,0" Margin="8,0,8,0"
                                                                Command="{Binding DataContext.ConnectToSavedDeviceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding Address}"/>
                                                        <Button Grid.Column="2" Content="Set default"
                                                                Style="{StaticResource TonalButton}"
                                                                Height="34" Padding="12,0" Margin="0,0,8,0"
                                                                Command="{Binding DataContext.SetDefaultSavedDeviceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding Address}"
                                                                Visibility="{Binding IsDefault, Converter={StaticResource InverseBoolConverter}}"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="Default"
                                                                   FontSize="12"
                                                                   FontWeight="Medium"
                                                                   Foreground="{DynamicResource AccentGreen}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,12,0"
                                                                   Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        <Button Grid.Column="3" Content="Forget"
                                                                Style="{StaticResource TonalButton}"
                                                                Foreground="{DynamicResource AccentRed}"
                                                                BorderBrush="{DynamicResource AccentRed}"
                                                                Height="34" Padding="12,0"
                                                                Command="{Binding DataContext.ForgetDeviceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding Address}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Text="No saved devices yet."
                                               FontSize="14" Foreground="{DynamicResource TextMuted}"
                                               Margin="0,0,0,12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasOtherKnownDevices}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Rectangle Fill="{DynamicResource Border}" Height="1" Margin="0,4,0,16"/>
                                    <TextBlock Text="SCAN AND PAIR" Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding StatusBt}"
                                               FontSize="14" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Content="Scan for devices"
                                                Style="{StaticResource TonalButton}"
                                                Command="{Binding ScanCommand}"
                                                Padding="20,0" Margin="0,0,12,0"
                                                IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBoolConverter}}"/>
                                        <Button Content="Open Bluetooth Settings"
                                                Style="{StaticResource TonalButton}"
                                                Padding="20,0"
                                                Command="{Binding OpenBtSettingsCommand}"/>
                                    </StackPanel>
                                    <ComboBox ItemsSource="{Binding Devices}"
                                              SelectedItem="{Binding SelectedDevice}"
                                              DisplayMemberPath="Name"
                                              Margin="0,0,0,12"
                                              Visibility="{Binding Devices.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                                    <Button Content="Connect to selected device"
                                            Style="{StaticResource PrimaryButton}"
                                            Command="{Binding ConnectCommand}"
                                            Padding="24,0" HorizontalAlignment="Left"
                                            Visibility="{Binding Devices.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                                </StackPanel>
                            </Border>

                            <Border Margin="0,0,0,20"
                                    Background="{DynamicResource AccentAmberLight}" CornerRadius="16" Padding="20"
                                    BorderBrush="{DynamicResource AccentAmber}" BorderThickness="1"
                                    Visibility="{Binding HasPairingGuidance, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="How to connect"
                                               FontSize="14" FontWeight="Medium"
                                               Foreground="{DynamicResource AccentAmber}" Margin="0,0,0,10"/>
                                    <TextBlock Text="{Binding PairingGuidance}"
                                               FontSize="14" Foreground="{DynamicResource TextPrimary}"
                                               TextWrapping="Wrap" LineHeight="22"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsAppearanceSettingsSectionSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="APPEARANCE" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                                    <Border Background="{DynamicResource BgHover}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <TextBlock Text="Text size and zoom"
                                                               FontSize="16" FontWeight="Medium"
                                                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding UiScaleDescription}"
                                                               FontSize="14" Foreground="{DynamicResource TextMuted}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <Border Grid.Column="1"
                                                        Background="{DynamicResource BgMain}"
                                                        BorderBrush="{DynamicResource Border}"
                                                        BorderThickness="1"
                                                        CornerRadius="999"
                                                        Padding="12,6"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding UiScaleLabel}"
                                                               FontSize="12"
                                                               FontWeight="Medium"
                                                               Foreground="{DynamicResource AccentBlue}"/>
                                                </Border>
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="A"
                                                           FontSize="12"
                                                           Margin="0,0,10,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextMuted}"/>
                                                <Slider Grid.Column="1"
                                                        x:Name="UiScaleSlider"
                                                        Minimum="100"
                                                        Maximum="115"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="True"
                                                        Value="{Binding UiScaleDraftPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        ValueChanged="UiScaleSlider_ValueChanged"
                                                        PreviewMouseLeftButtonUp="UiScaleSlider_PreviewMouseLeftButtonUp"
                                                        LostMouseCapture="UiScaleSlider_LostMouseCapture"
                                                        VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="A"
                                                           FontSize="18"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                <Button Grid.Column="3"
                                                        Content="Reset"
                                                        Style="{StaticResource TonalButton}"
                                                        Margin="16,0,0,0"
                                                        Padding="16,0"
                                                        Click="ResetTextSizeButton_Click"
                                                        Visibility="{Binding IsDefaultUiScale, Converter={StaticResource InverseBoolConverter}}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{DynamicResource BgHover}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Dark mode"
                                                           FontSize="16" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding ThemeModeLabel}"
                                                            FontSize="14" Foreground="{DynamicResource TextMuted}"/>
                                            </StackPanel>
                                            <ToggleButton Grid.Column="1"
                                                          Margin="0,0,10,0"
                                                          Style="{StaticResource SwitchToggleButtonStyle}"
                                                          IsChecked="{Binding IsDarkModeEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                    </Border>
                                    <Border Background="{DynamicResource BgHover}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Sync theme with Shamash app"
                                                           FontSize="16" FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding ThemeSyncLabel}"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding ThemeSyncRefreshStatus}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,0"
                                                           Visibility="{Binding ThemeSyncRefreshStatus, Converter={StaticResource NullOrEmptyToCollapsedConverter}}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Button Content="Refresh sync"
                                                        Style="{StaticResource TonalButton}"
                                                        Height="34"
                                                        Padding="14,0"
                                                        Margin="0,0,12,0"
                                                        Command="{Binding RefreshThemeSyncCommand}"/>
                                                <ToggleButton Margin="0,0,10,0"
                                                              Style="{StaticResource SwitchToggleButtonStyle}"
                                                              IsChecked="{Binding SyncThemeWithShamash, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Background="{DynamicResource BgHover}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="History Background Fetching"
                                                       VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"
                                                       FontWeight="Medium" FontSize="14"/>
                                            <ToggleButton Grid.Column="1" Margin="0,0,10,0" Padding="12,6" FontSize="14"
                                                          IsChecked="{Binding PauseHistoryActivity}">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton">
                                                        <Setter Property="Content" Value="History Active"/>
                                                        <Setter Property="Background" Value="#E6F4EA"/>
                                                        <Setter Property="Foreground" Value="#1E8E3E"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter Property="Content" Value="History Paused"/>
                                                                <Setter Property="Background" Value="#FCE8E6"/>
                                                                <Setter Property="Foreground" Value="#D93025"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                        </Grid>
                                    </Border>
                                    <Border Background="{DynamicResource BgHover}" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="UI auditor"
                                                           FontSize="16"
                                                           FontWeight="Medium"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           Margin="0,0,0,4"/>
                                                <TextBlock Text="Run the DeskPhone layout and accessibility audit."
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextMuted}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="Open Auditor"
                                                    Style="{StaticResource TonalButton}"
                                                    Padding="18,0"
                                                    Click="OpenUiAuditorButton_Click"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsSyncSettingsSectionSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="CONTACT SYNC" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                                    <TextBlock Text="{Binding ContactSyncStatus}"
                                               FontSize="14" Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,12"/>
                                    <TextBlock Text="DeskPhone now queues local contact adds, edits, and deletes to the per-phone sync outbox when a real helper contract exists. PBAP itself does not write contacts back to the handset."
                                               FontSize="12" Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,12"/>
                                    <Border Background="{DynamicResource BgHover}" CornerRadius="12" Padding="14,10" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="Starter VCF or synced per-phone folder"
                                                       FontSize="14" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <TextBlock Text="{Binding ContactSyncFolderPath}"
                                                       FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                       Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            <TextBlock Margin="0,8,0,0"
                                                       FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                       Text="{Binding ContactCountText}"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Import starter VCF"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="20,0" Margin="0,0,12,0"
                                                Command="{Binding ImportStarterVcfCommand}"/>
                                        <Button Content="Import synced contacts"
                                                Style="{StaticResource TonalButton}"
                                                Padding="20,0" Margin="0,0,12,0"
                                                Command="{Binding ImportPendingContactsCommand}"
                                                Visibility="{Binding PendingContactFiles, Converter={StaticResource CountToVisibilityConverter}}"/>
                                        <Button Content="Ignore pending"
                                                Style="{StaticResource TonalButton}"
                                                Padding="20,0" Margin="0,0,12,0"
                                                Command="{Binding SkipPendingContactsCommand}"
                                                Visibility="{Binding PendingContactFiles, Converter={StaticResource CountToVisibilityConverter}}"/>
                                        <Button Content="Open contact sync folder"
                                                Style="{StaticResource TonalButton}"
                                                Padding="20,0"
                                                Command="{Binding OpenContactSyncFolderCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="MESSAGE BACKUP EXPORT" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                                    <TextBlock Text="{Binding MessageBackupExportStatus}"
                                               FontSize="14" Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap" LineHeight="20" Margin="0,0,0,12"/>
                                    <TextBlock Text="Exports the current DeskPhone message store to a JSON file at a location you choose. This is separate from the app's automatic rotating safety backups."
                                               FontSize="12" Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Save messages backup"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="20,0"
                                                Command="{Binding ExportMessagesBackupCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="PHONE CALL-LOG SYNC" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                                    <TextBlock Text="PBAP connection"
                                               FontSize="16" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                                    <Border Background="{DynamicResource BgHover}" CornerRadius="999" Padding="10,4"
                                            HorizontalAlignment="Left" Margin="0,0,0,12">
                                        <TextBlock Text="{Binding PbapBadgeText}"
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   Foreground="{Binding PbapBadgeForeground}"/>
                                    </Border>
                                    <TextBlock Text="{Binding PbapStatus}"
                                               FontSize="14" Foreground="{DynamicResource TextMuted}"
                                               TextWrapping="Wrap" LineHeight="20"/>
                                    <Border Background="{DynamicResource AccentAmberLight}"
                                            CornerRadius="16"
                                            Padding="16"
                                            Margin="0,14,0,0"
                                            BorderBrush="{DynamicResource AccentAmber}"
                                            BorderThickness="1"
                                            Visibility="{Binding HasPbapGuidance, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding PbapGuidanceTitle}"
                                                       FontSize="14"
                                                       FontWeight="Medium"
                                                       Foreground="{DynamicResource AccentAmber}"
                                                       Margin="0,0,0,8"/>
                                            <TextBlock Text="{Binding PbapGuidance}"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextPrimary}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="22"/>
                                            <Button Content="Open Bluetooth Settings"
                                                    Style="{StaticResource TonalButton}"
                                                    Padding="18,0"
                                                    Margin="0,12,0,0"
                                                    HorizontalAlignment="Left"
                                                    Command="{Binding OpenBtSettingsCommand}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Visibility="{Binding IsAudioSettingsSectionSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="AUDIO" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Audio Routing"
                                               FontSize="16" FontWeight="Medium"
                                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding AudioInfo}"
                                               FontSize="14" Foreground="{DynamicResource TextSecond}"
                                               TextWrapping="Wrap" LineHeight="22"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                                        <Button Content="Refresh"
                                                Style="{StaticResource TonalButton}"
                                                Margin="0,0,12,0" Padding="20,0"
                                                Click="RefreshAudioButton_Click"/>
                                        <Button Content="Open Sound Settings"
                                                Style="{StaticResource PrimaryButton}"
                                                Padding="20,0"
                                                Command="{Binding OpenSoundSettingsCommand}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="Call Audio Console"
                                                Style="{StaticResource PrimaryButton}"
                                                Margin="0,0,12,0" Padding="20,0"
                                                Command="{Binding OpenAudioConsoleCommand}"/>
                                        <Button Content="Open Shamash Web UI"
                                                Style="{StaticResource TonalButton}"
                                                Padding="20,0"
                                                Command="{Binding OpenShamashUiCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,32">
                                <StackPanel>
                                    <TextBlock Text="PLAYBACK DEVICES" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                                    <ItemsControl ItemsSource="{Binding PlaybackDevices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Ellipse Width="8" Height="8" Margin="0,0,10,0"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource TextDisabled}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource AccentGreen}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text=" (default)"
                                                               FontSize="12" FontWeight="Medium"
                                                               Foreground="{DynamicResource AccentGreen}"
                                                               VerticalAlignment="Center" Margin="4,0,0,0"
                                                               Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,32">
                                <StackPanel>
                                    <TextBlock Text="MICROPHONE DEVICES" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>
                                    <ItemsControl ItemsSource="{Binding RecordingDevices}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <Ellipse Width="8" Height="8" Margin="0,0,10,0"
                                                             VerticalAlignment="Center">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{DynamicResource TextDisabled}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                                        <Setter Property="Fill" Value="{DynamicResource AccentGreen}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text=" (default)"
                                                               FontSize="12" FontWeight="Medium"
                                                               Foreground="{DynamicResource AccentGreen}"
                                                               VerticalAlignment="Center" Margin="4,0,0,0"
                                                               Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- - Call Audio Routing -->
                            <Border Style="{StaticResource Card}" Margin="0,0,0,32">
                                <StackPanel>
                                    <TextBlock Text="CALL AUDIO ROUTING" Style="{StaticResource SectionLabel}" Margin="0,0,0,12"/>

                                    <!-- Live summary line -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="{DynamicResource TextDisabled}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCallAudioRouteExternal}" Value="True">
                                                            <Setter Property="Fill" Value="{DynamicResource AccentGreen}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock Text="{Binding CallAudioRouteSummary}"
                                                   FontSize="14" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Current Windows default communications device -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                        <TextBlock Text="Windows default: " FontSize="14" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextSecond}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding CallAudioRouteDeviceName}"
                                                   FontSize="14" Foreground="{DynamicResource TextPrimary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Why this matters explanation -->
                                    <Border Background="{DynamicResource SurfaceVariant}"
                                            CornerRadius="8" Padding="12" Margin="0,0,0,0">
                                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecond}"
                                                   TextWrapping="Wrap" LineHeight="18">
                                            <Run FontWeight="Medium" Foreground="{DynamicResource TextPrimary}">Why this matters.</Run>
                                            <Run> Windows on this hardware can't route Bluetooth call audio from a phone to PC speakers  -  the Microsoft Bluetooth stack only supports the headset-side role. Your phone holds the call audio. To use the PC as a desk speakerphone, plug in a USB Bluetooth speakerphone (Jabra Speak 510, Poly Sync 20+, Yealink CP900, etc.); pair it to the phone and set it as the Windows default communications device. DeskPhone keeps doing call control over Bluetooth either way.</Run>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- ================================================================ -->
            <!-- TAB: DEVELOPER TOOLS                                        -->
            <!-- ================================================================ -->
            <ScrollViewer Grid.Row="3" Padding="40,32" Background="{DynamicResource BgSidebar}">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer" BasedOn="{StaticResource TouchScrollViewerStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChecked, ElementName=TabDeveloperTools}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel MaxWidth="700" HorizontalAlignment="Left">
                    <TextBlock Text="Developer Tools" FontSize="28" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Build history, logs, and diagnostic tools."
                               FontSize="14"
                               Foreground="{DynamicResource TextMuted}"
                               Margin="0,0,0,18"/>

                    <WrapPanel Margin="0,0,0,24">
                        <Button Content="Open builds folder"
                                Style="{StaticResource TonalButton}"
                                Height="36"
                                Padding="16,0"
                                Margin="0,0,10,10"
                                Command="{Binding OpenBuildsFolderCommand}"/>
                        <Button Content="Open event log"
                                Style="{StaticResource TonalButton}"
                                Height="36"
                                Padding="16,0"
                                Margin="0,0,10,10"
                                Click="OpenLiveLogButton_Click"/>
                        <Button Content="Run UI auditor"
                                Style="{StaticResource TonalButton}"
                                Height="36"
                                Padding="16,0"
                                Margin="0,0,10,10"
                                Click="OpenUiAuditorButton_Click"/>
                    </WrapPanel>

                    <TextBlock Text="Changelog" FontSize="22" FontWeight="Medium"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding Changelog}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Version}"
                                                       FontSize="18" FontWeight="Medium"
                                                       Foreground="{DynamicResource AccentBlue}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Timestamp}"
                                                       FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Notes}"
                                                   FontSize="14" Foreground="{DynamicResource TextPrimary}"
                                                   Margin="0,8,0,0" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding DevNotes}"
                                                   FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                   Margin="0,8,0,0" TextWrapping="Wrap"
                                                   FontFamily="Cascadia Code, Consolas, monospace"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- ================================================================ -->
        </Grid>
    </Grid>
</Window>
