                                                                            <Button Grid.Column="2"
                                                                                    Content="Save"
                                                                                    MinWidth="56"
                                                                                    Height="28"
                                                                                    Padding="12,0"
                                                                                    Margin="10,0,0,0"
                                                                                    Style="{StaticResource TonalButton}"
                                                                                    Command="{Binding DataContext.SaveAttachmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                    CommandParameter="{Binding}"/>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <Grid Margin="0,5,0,0">
