                                                        <ContextMenu>
                                                            <MenuItem Header="Copy" Click="BubbleCopy_Click"/>
                                                            <MenuItem Header="Forward..." Click="BubbleForward_Click"/>
                                                            <MenuItem Header="Call" Click="BubbleCall_Click"/>
                                                            <MenuItem Header="{Binding PinActionLabel}" Click="BubblePin_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="Delete" Click="BubbleDelete_Click"/>
                                                        </ContextMenu>
                                                    </Border.ContextMenu>
                                                    <StackPanel>
                                                        <!-- Text body: shown when Body is non-empty -->
