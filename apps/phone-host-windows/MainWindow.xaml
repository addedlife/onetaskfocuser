                                                                <Button Content="&#xE154;"
                                                                        Style="{StaticResource BubbleActionButtonStyle}"
                                                                        ToolTip="Forward"
                                                                        Click="BubbleActionForwardButton_Click"/>
                                                                <Button Content="&#xE0B0;"
                                                                        Style="{StaticResource BubbleActionButtonStyle}"
                                                                        ToolTip="Call"
                                                                        Click="BubbleActionCallButton_Click"/>
                                                                <Button Content="&#xE872;"
                                                                        Style="{StaticResource BubbleActionButtonStyle}"
                                                                        ToolTip="Delete"
