                                                                            <DataTrigger Binding="{Binding IsSendFailed}" Value="True">
                                                                                <Setter Property="Foreground" Value="#FFFFCDD2"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding OutgoingStatusLabel}"
                                                                       FontSize="11"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#99FFFFFF"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSendFailed}" Value="True">
                                                                                <Setter Property="Foreground" Value="#FFFFCDD2"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Grid.Column="2"
                                                                       Text="&#xE5D5;"
                                                                       Style="{StaticResource MaterialIconText}"
                                                                       FontSize="14"
                                                                       Foreground="#FFFFCDD2"
                                                                       Margin="8,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       ToolTip="Retry send"
