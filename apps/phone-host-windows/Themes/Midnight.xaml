<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Midnight (deep blue-black) theme ─────────────────────────────── -->

    <!-- Background surfaces -->
    <SolidColorBrush x:Key="BgMain"          Color="#0D1117"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="#080D13"/>
    <SolidColorBrush x:Key="BgHover"         Color="#161B22"/>
    <SolidColorBrush x:Key="BgInput"         Color="#0D1117"/>
    <SolidColorBrush x:Key="BgSelected"      Color="#1F3558"/>

    <!-- Brand colours -->
    <SolidColorBrush x:Key="AccentBlue"      Color="#58A6FF"/>
    <SolidColorBrush x:Key="AccentBlueDark"  Color="#388BFD"/>
    <SolidColorBrush x:Key="AccentBlueLight" Color="#0D2040"/>
    <SolidColorBrush x:Key="AccentGreen"     Color="#3FB950"/>
    <SolidColorBrush x:Key="AccentGreenDark" Color="#2EA043"/>
    <SolidColorBrush x:Key="AccentGreenLight" Color="#0A2A10"/>
    <SolidColorBrush x:Key="AccentRed"       Color="#F85149"/>
    <SolidColorBrush x:Key="AccentRedDark"   Color="#DA3633"/>
    <SolidColorBrush x:Key="AccentRedLight"  Color="#2A0E0E"/>

    <SolidColorBrush x:Key="AccentAmber"      Color="#E3B341"/>
    <SolidColorBrush x:Key="AccentAmberDark"  Color="#BB8009"/>
    <SolidColorBrush x:Key="AccentAmberLight" Color="#2A1A00"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="TextPrimary"     Color="#E6EDF3"/>
    <SolidColorBrush x:Key="TextSecond"      Color="#C9D1D9"/>
    <SolidColorBrush x:Key="TextMuted"       Color="#8B949E"/>
    <SolidColorBrush x:Key="TextDisabled"    Color="#484F58"/>
    <SolidColorBrush x:Key="TextOnAccent"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnAccentBlueLight" Color="#58A6FF"/>

    <!-- Outline / dividers -->
    <SolidColorBrush x:Key="Border"          Color="#21262D"/>
    <SolidColorBrush x:Key="BorderFocus"     Color="#58A6FF"/>

    <!-- Chat bubbles -->
    <SolidColorBrush x:Key="BubbleIn"        Color="#161B22"/>
    <SolidColorBrush x:Key="BubbleInBorder"  Color="#21262D"/>
    <SolidColorBrush x:Key="BubbleOut"       Color="#1F3558"/>
    <SolidColorBrush x:Key="BubbleOutText"   Color="#E6EDF3"/>

    <Color x:Key="ShadowColor">#80000000</Color>

</ResourceDictionary>
