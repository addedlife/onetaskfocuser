<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Pure light: mirrors the web phone screen palette (GV_CLEAN + 10-deskphone-web COLORS).
         Teal accent (#00796B) and Google greys — keep in lockstep with
         apps/web/src/08-app-split/ui-tokens.jsx and apps/web/src/10-deskphone-web.jsx. -->
    <SolidColorBrush x:Key="Primary"             Color="#00796B"/>
    <SolidColorBrush x:Key="OnPrimary"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryContainer"    Color="#E0F2F1"/>
    <SolidColorBrush x:Key="OnPrimaryContainer"  Color="#003731"/>

    <SolidColorBrush x:Key="Secondary"             Color="#5F6368"/>
    <SolidColorBrush x:Key="OnSecondary"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryContainer"    Color="#E0F2F1"/>
    <SolidColorBrush x:Key="OnSecondaryContainer"  Color="#003731"/>

    <SolidColorBrush x:Key="Tertiary"             Color="#1E8E3E"/>
    <SolidColorBrush x:Key="OnTertiary"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TertiaryContainer"    Color="#CEEAD6"/>
    <SolidColorBrush x:Key="OnTertiaryContainer"  Color="#137333"/>

    <SolidColorBrush x:Key="Error"             Color="#D93025"/>
    <SolidColorBrush x:Key="OnError"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorContainer"    Color="#FCE8E6"/>
    <SolidColorBrush x:Key="OnErrorContainer"  Color="#5B1010"/>

    <SolidColorBrush x:Key="Background"              Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OnBackground"            Color="#202124"/>
    <SolidColorBrush x:Key="Surface"                 Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OnSurface"               Color="#202124"/>
    <SolidColorBrush x:Key="SurfaceVariant"          Color="#F1F3F4"/>
    <SolidColorBrush x:Key="OnSurfaceVariant"        Color="#3C4043"/>
    <SolidColorBrush x:Key="SurfaceContainerLowest"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceContainerLow"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceContainer"        Color="#F1F3F4"/>
    <SolidColorBrush x:Key="SurfaceContainerHigh"    Color="#E8EAED"/>
    <SolidColorBrush x:Key="SurfaceContainerHighest" Color="#DADCE0"/>
    <SolidColorBrush x:Key="Outline"                 Color="#5F6368"/>
    <SolidColorBrush x:Key="OutlineVariant"          Color="#DADCE0"/>

    <SolidColorBrush x:Key="BgMain"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgHover"         Color="#F1F3F4"/>
    <SolidColorBrush x:Key="BgInput"         Color="#F8F9FA"/>
    <SolidColorBrush x:Key="BgSelected"      Color="#E0F2F1"/>

    <SolidColorBrush x:Key="AccentBlue"      Color="#00796B"/>
    <SolidColorBrush x:Key="AccentBlueDark"  Color="#00695C"/>
    <SolidColorBrush x:Key="AccentBlueLight" Color="#E0F2F1"/>
    <SolidColorBrush x:Key="AccentGreen"      Color="#1E8E3E"/>
    <SolidColorBrush x:Key="AccentGreenDark"  Color="#137333"/>
    <SolidColorBrush x:Key="AccentGreenLight" Color="#CEEAD6"/>
    <SolidColorBrush x:Key="AccentRed"        Color="#D93025"/>
    <SolidColorBrush x:Key="AccentRedDark"    Color="#8F1F1F"/>
    <SolidColorBrush x:Key="AccentRedLight"   Color="#FCE8E6"/>
    <SolidColorBrush x:Key="AccentAmber"      Color="#B06000"/>
    <SolidColorBrush x:Key="AccentAmberDark"  Color="#854900"/>
    <SolidColorBrush x:Key="AccentAmberLight" Color="#FFE8B3"/>

    <SolidColorBrush x:Key="TextPrimary"           Color="#202124"/>
    <SolidColorBrush x:Key="TextSecond"            Color="#3C4043"/>
    <SolidColorBrush x:Key="TextMuted"             Color="#5F6368"/>
    <SolidColorBrush x:Key="TextDisabled"          Color="#9AA0A6"/>
    <SolidColorBrush x:Key="TextOnAccent"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnAccentBlueLight" Color="#00695C"/>

    <SolidColorBrush x:Key="Border"      Color="#DADCE0"/>
    <SolidColorBrush x:Key="BorderFocus" Color="#00796B"/>

    <SolidColorBrush x:Key="BubbleIn"        Color="#F8F9FA"/>
    <SolidColorBrush x:Key="BubbleInBorder"  Color="#DADCE0"/>
    <SolidColorBrush x:Key="BubbleOut"       Color="#00796B"/>
    <SolidColorBrush x:Key="BubbleOutText"   Color="#FFFFFF"/>

    <Color x:Key="ShadowColor">#260F172A</Color>

</ResourceDictionary>
