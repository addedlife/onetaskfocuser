<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Pure light: Google Material 3 palette with readable contrast. -->
    <SolidColorBrush x:Key="Primary"             Color="#0B57D0"/>
    <SolidColorBrush x:Key="OnPrimary"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryContainer"    Color="#D3E3FD"/>
    <SolidColorBrush x:Key="OnPrimaryContainer"  Color="#041E49"/>

    <SolidColorBrush x:Key="Secondary"             Color="#526070"/>
    <SolidColorBrush x:Key="OnSecondary"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryContainer"    Color="#E3E9F1"/>
    <SolidColorBrush x:Key="OnSecondaryContainer"  Color="#1D2733"/>

    <SolidColorBrush x:Key="Tertiary"             Color="#0B8043"/>
    <SolidColorBrush x:Key="OnTertiary"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TertiaryContainer"    Color="#D8F3E8"/>
    <SolidColorBrush x:Key="OnTertiaryContainer"  Color="#0D3A29"/>

    <SolidColorBrush x:Key="Error"             Color="#BA2A2A"/>
    <SolidColorBrush x:Key="OnError"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorContainer"    Color="#FFE1E1"/>
    <SolidColorBrush x:Key="OnErrorContainer"  Color="#5B1010"/>

    <SolidColorBrush x:Key="Background"              Color="#F8FAFD"/>
    <SolidColorBrush x:Key="OnBackground"            Color="#182230"/>
    <SolidColorBrush x:Key="Surface"                 Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OnSurface"               Color="#182230"/>
    <SolidColorBrush x:Key="SurfaceVariant"          Color="#E8EDF5"/>
    <SolidColorBrush x:Key="OnSurfaceVariant"        Color="#465568"/>
    <SolidColorBrush x:Key="SurfaceContainerLowest"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceContainerLow"     Color="#FDFEFF"/>
    <SolidColorBrush x:Key="SurfaceContainer"        Color="#F1F4F9"/>
    <SolidColorBrush x:Key="SurfaceContainerHigh"    Color="#E8EDF5"/>
    <SolidColorBrush x:Key="SurfaceContainerHighest" Color="#DDE5F0"/>
    <SolidColorBrush x:Key="Outline"                 Color="#64748B"/>
    <SolidColorBrush x:Key="OutlineVariant"          Color="#D6DDE8"/>

    <SolidColorBrush x:Key="BgMain"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="#F8FAFD"/>
    <SolidColorBrush x:Key="BgHover"         Color="#EEF3FA"/>
    <SolidColorBrush x:Key="BgInput"         Color="#F1F4F9"/>
    <SolidColorBrush x:Key="BgSelected"      Color="#D3E3FD"/>

    <SolidColorBrush x:Key="AccentBlue"      Color="#0B57D0"/>
    <SolidColorBrush x:Key="AccentBlueDark"  Color="#0842A0"/>
    <SolidColorBrush x:Key="AccentBlueLight" Color="#D3E3FD"/>
    <SolidColorBrush x:Key="AccentGreen"      Color="#0B8043"/>
    <SolidColorBrush x:Key="AccentGreenDark"  Color="#076335"/>
    <SolidColorBrush x:Key="AccentGreenLight" Color="#D8F3E8"/>
    <SolidColorBrush x:Key="AccentRed"        Color="#BA2A2A"/>
    <SolidColorBrush x:Key="AccentRedDark"    Color="#8F1F1F"/>
    <SolidColorBrush x:Key="AccentRedLight"   Color="#FFE1E1"/>
    <SolidColorBrush x:Key="AccentAmber"      Color="#B06000"/>
    <SolidColorBrush x:Key="AccentAmberDark"  Color="#854900"/>
    <SolidColorBrush x:Key="AccentAmberLight" Color="#FFE8B3"/>

    <SolidColorBrush x:Key="TextPrimary"           Color="#182230"/>
    <SolidColorBrush x:Key="TextSecond"            Color="#334155"/>
    <SolidColorBrush x:Key="TextMuted"             Color="#64748B"/>
    <SolidColorBrush x:Key="TextDisabled"          Color="#98A4B3"/>
    <SolidColorBrush x:Key="TextOnAccent"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnAccentBlueLight" Color="#041E49"/>

    <SolidColorBrush x:Key="Border"      Color="#D6DDE8"/>
    <SolidColorBrush x:Key="BorderFocus" Color="#0B57D0"/>

    <SolidColorBrush x:Key="BubbleIn"        Color="#F1F4F9"/>
    <SolidColorBrush x:Key="BubbleInBorder"  Color="#D6DDE8"/>
    <SolidColorBrush x:Key="BubbleOut"       Color="#0B57D0"/>
    <SolidColorBrush x:Key="BubbleOutText"   Color="#FFFFFF"/>

    <Color x:Key="ShadowColor">#260F172A</Color>

</ResourceDictionary>
