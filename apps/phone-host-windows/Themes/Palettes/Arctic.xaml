<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Arctic — crisp ice-white, sky cyan accent ─────────────────────── -->
    <!-- Pure whites with a cold blue tint, vivid cyan/sky accent.           -->
    <!-- Sharp, clinical, clean. Like frosted glass and arctic air.          -->

    <SolidColorBrush x:Key="BgMain"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="#F0F6FC"/>
    <SolidColorBrush x:Key="BgHover"         Color="#E2EEF8"/>
    <SolidColorBrush x:Key="BgInput"         Color="#EAF3FA"/>
    <SolidColorBrush x:Key="BgSelected"      Color="#C8E4F8"/>

    <!-- Sky/cyan accent -->
    <SolidColorBrush x:Key="AccentBlue"      Color="#0284C7"/>
    <SolidColorBrush x:Key="AccentBlueDark"  Color="#0369A1"/>
    <SolidColorBrush x:Key="AccentBlueLight" Color="#BAE6FD"/>
    <!-- Success — fresh teal -->
    <SolidColorBrush x:Key="AccentGreen"     Color="#0D9488"/>
    <SolidColorBrush x:Key="AccentGreenDark" Color="#0A7A72"/>
    <SolidColorBrush x:Key="AccentGreenLight" Color="#CCFBF1"/>
    <!-- Danger — vivid rose -->
    <SolidColorBrush x:Key="AccentRed"       Color="#DC2626"/>
    <SolidColorBrush x:Key="AccentRedDark"   Color="#B91C1C"/>
    <SolidColorBrush x:Key="AccentRedLight"  Color="#FEE2E2"/>
    <!-- Amber — cold yellow -->
    <SolidColorBrush x:Key="AccentAmber"      Color="#D97706"/>
    <SolidColorBrush x:Key="AccentAmberDark"  Color="#B45309"/>
    <SolidColorBrush x:Key="AccentAmberLight" Color="#FEF3C7"/>

    <SolidColorBrush x:Key="TextPrimary"     Color="#0C1B2E"/>
    <SolidColorBrush x:Key="TextSecond"      Color="#1E3A55"/>
    <SolidColorBrush x:Key="TextMuted"       Color="#6690AA"/>
    <SolidColorBrush x:Key="TextDisabled"    Color="#B8D0E0"/>
    <SolidColorBrush x:Key="TextOnAccent"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnAccentBlueLight" Color="#0C4A6E"/>

    <SolidColorBrush x:Key="Border"          Color="#D0E4F0"/>
    <SolidColorBrush x:Key="BorderFocus"     Color="#0284C7"/>

    <!-- Received: pure white; Sent: sky blue -->
    <SolidColorBrush x:Key="BubbleIn"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BubbleInBorder"  Color="#D0E4F0"/>
    <SolidColorBrush x:Key="BubbleOut"       Color="#0284C7"/>
    <SolidColorBrush x:Key="BubbleOutText"   Color="#FFFFFF"/>

    <Color x:Key="ShadowColor">#25000000</Color>

</ResourceDictionary>
