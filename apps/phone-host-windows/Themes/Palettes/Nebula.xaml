<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Nebula — deep purple-black, luminous violet/magenta glow ──────── -->
    <!-- Almost-black purple backgrounds, vivid electric violet accent,      -->
    <!-- hot-pink highlights. Lush and dramatic. Like a supernova.           -->

    <SolidColorBrush x:Key="BgMain"          Color="#0E0A1A"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="#090612"/>
    <SolidColorBrush x:Key="BgHover"         Color="#1A1228"/>
    <SolidColorBrush x:Key="BgInput"         Color="#140F22"/>
    <SolidColorBrush x:Key="BgSelected"      Color="#2A1850"/>

    <!-- Electric violet accent -->
    <SolidColorBrush x:Key="AccentBlue"      Color="#C084FC"/>
    <SolidColorBrush x:Key="AccentBlueDark"  Color="#A060E0"/>
    <SolidColorBrush x:Key="AccentBlueLight" Color="#1E0A40"/>
    <!-- Success — bright cyan-mint -->
    <SolidColorBrush x:Key="AccentGreen"     Color="#34ECA8"/>
    <SolidColorBrush x:Key="AccentGreenDark" Color="#22C88A"/>
    <SolidColorBrush x:Key="AccentGreenLight" Color="#081E18"/>
    <!-- Danger — hot coral -->
    <SolidColorBrush x:Key="AccentRed"       Color="#FF5C8A"/>
    <SolidColorBrush x:Key="AccentRedDark"   Color="#E03A68"/>
    <SolidColorBrush x:Key="AccentRedLight"  Color="#280A14"/>
    <!-- Amber — electric gold -->
    <SolidColorBrush x:Key="AccentAmber"      Color="#FFBE0B"/>
    <SolidColorBrush x:Key="AccentAmberDark"  Color="#E0A008"/>
    <SolidColorBrush x:Key="AccentAmberLight" Color="#241A04"/>

    <SolidColorBrush x:Key="TextPrimary"     Color="#F0E8FF"/>
    <SolidColorBrush x:Key="TextSecond"      Color="#C8B4F0"/>
    <SolidColorBrush x:Key="TextMuted"       Color="#6040A0"/>
    <SolidColorBrush x:Key="TextDisabled"    Color="#341E60"/>
    <SolidColorBrush x:Key="TextOnAccent"    Color="#0E0A1A"/>
    <SolidColorBrush x:Key="TextOnAccentBlueLight" Color="#C084FC"/>

    <SolidColorBrush x:Key="Border"          Color="#241640"/>
    <SolidColorBrush x:Key="BorderFocus"     Color="#C084FC"/>

    <!-- Received: deep purple card; Sent: violet gradient approximation -->
    <SolidColorBrush x:Key="BubbleIn"        Color="#1A1228"/>
    <SolidColorBrush x:Key="BubbleInBorder"  Color="#241640"/>
    <SolidColorBrush x:Key="BubbleOut"       Color="#3D1880"/>
    <SolidColorBrush x:Key="BubbleOutText"   Color="#F0E8FF"/>

    <Color x:Key="ShadowColor">#90000000</Color>

</ResourceDictionary>
