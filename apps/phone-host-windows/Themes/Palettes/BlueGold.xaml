<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Pure dark: navy-gold command surface with high-contrast Material tokens. -->
    <SolidColorBrush x:Key="Primary"             Color="#F2C14E"/>
    <SolidColorBrush x:Key="OnPrimary"           Color="#1F1600"/>
    <SolidColorBrush x:Key="PrimaryContainer"    Color="#3A321B"/>
    <SolidColorBrush x:Key="OnPrimaryContainer"  Color="#FFE7A3"/>

    <SolidColorBrush x:Key="Secondary"             Color="#A9B6C8"/>
    <SolidColorBrush x:Key="OnSecondary"           Color="#10161F"/>
    <SolidColorBrush x:Key="SecondaryContainer"    Color="#263140"/>
    <SolidColorBrush x:Key="OnSecondaryContainer"  Color="#E1E7F0"/>

    <SolidColorBrush x:Key="Tertiary"             Color="#61D6B3"/>
    <SolidColorBrush x:Key="OnTertiary"           Color="#041B15"/>
    <SolidColorBrush x:Key="TertiaryContainer"    Color="#123F34"/>
    <SolidColorBrush x:Key="OnTertiaryContainer"  Color="#D4F8EC"/>

    <SolidColorBrush x:Key="Error"             Color="#FF8A8A"/>
    <SolidColorBrush x:Key="OnError"           Color="#2B0707"/>
    <SolidColorBrush x:Key="ErrorContainer"    Color="#5C1B20"/>
    <SolidColorBrush x:Key="OnErrorContainer"  Color="#FFD9DC"/>

    <SolidColorBrush x:Key="Background"              Color="#07111F"/>
    <SolidColorBrush x:Key="OnBackground"            Color="#F7FAFF"/>
    <SolidColorBrush x:Key="Surface"                 Color="#122235"/>
    <SolidColorBrush x:Key="OnSurface"               Color="#F7FAFF"/>
    <SolidColorBrush x:Key="SurfaceVariant"          Color="#304258"/>
    <SolidColorBrush x:Key="OnSurfaceVariant"        Color="#C7D2E1"/>
    <SolidColorBrush x:Key="SurfaceContainerLowest"  Color="#040B14"/>
    <SolidColorBrush x:Key="SurfaceContainerLow"     Color="#0D1B2E"/>
    <SolidColorBrush x:Key="SurfaceContainer"        Color="#122235"/>
    <SolidColorBrush x:Key="SurfaceContainerHigh"    Color="#1A2D43"/>
    <SolidColorBrush x:Key="SurfaceContainerHighest" Color="#24384F"/>
    <SolidColorBrush x:Key="Outline"                 Color="#7B8CA2"/>
    <SolidColorBrush x:Key="OutlineVariant"          Color="#304258"/>

    <SolidColorBrush x:Key="BgMain"          Color="#122235"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="#07111F"/>
    <SolidColorBrush x:Key="BgHover"         Color="#1A2D43"/>
    <SolidColorBrush x:Key="BgInput"         Color="#0D1B2E"/>
    <SolidColorBrush x:Key="BgSelected"      Color="#3A321B"/>

    <SolidColorBrush x:Key="AccentBlue"      Color="#F2C14E"/>
    <SolidColorBrush x:Key="AccentBlueDark"  Color="#FFE7A3"/>
    <SolidColorBrush x:Key="AccentBlueLight" Color="#3A321B"/>
    <SolidColorBrush x:Key="AccentGreen"      Color="#61D6B3"/>
    <SolidColorBrush x:Key="AccentGreenDark"  Color="#B8F4DF"/>
    <SolidColorBrush x:Key="AccentGreenLight" Color="#123F34"/>
    <SolidColorBrush x:Key="AccentRed"        Color="#FF8A8A"/>
    <SolidColorBrush x:Key="AccentRedDark"    Color="#FFD9DC"/>
    <SolidColorBrush x:Key="AccentRedLight"   Color="#5C1B20"/>
    <SolidColorBrush x:Key="AccentAmber"      Color="#F2C14E"/>
    <SolidColorBrush x:Key="AccentAmberDark"  Color="#FFE1A8"/>
    <SolidColorBrush x:Key="AccentAmberLight" Color="#4A3514"/>

    <SolidColorBrush x:Key="TextPrimary"           Color="#F7FAFF"/>
    <SolidColorBrush x:Key="TextSecond"            Color="#D6DEE9"/>
    <SolidColorBrush x:Key="TextMuted"             Color="#A5B3C4"/>
    <SolidColorBrush x:Key="TextDisabled"          Color="#6F7F92"/>
    <SolidColorBrush x:Key="TextOnAccent"          Color="#1F1600"/>
    <SolidColorBrush x:Key="TextOnAccentBlueLight" Color="#FFE7A3"/>

    <SolidColorBrush x:Key="Border"      Color="#304258"/>
    <SolidColorBrush x:Key="BorderFocus" Color="#F2C14E"/>

    <SolidColorBrush x:Key="BubbleIn"        Color="#182B42"/>
    <SolidColorBrush x:Key="BubbleInBorder"  Color="#304258"/>
    <SolidColorBrush x:Key="BubbleOut"       Color="#F2C14E"/>
    <SolidColorBrush x:Key="BubbleOutText"   Color="#1F1600"/>

    <Color x:Key="ShadowColor">#AA000000</Color>

</ResourceDictionary>
