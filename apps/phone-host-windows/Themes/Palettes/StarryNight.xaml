<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Starry Night — luminous deep-space dark ───────────────────────── -->
    <!-- Very deep navy/indigo backgrounds, luminous ice-blue accent,        -->
    <!-- warm gold highlights. Like looking up at a clear night sky.         -->

    <SolidColorBrush x:Key="BgMain"          Color="#0B0F1E"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="#070A16"/>
    <SolidColorBrush x:Key="BgHover"         Color="#131A30"/>
    <SolidColorBrush x:Key="BgInput"         Color="#101626"/>
    <SolidColorBrush x:Key="BgSelected"      Color="#1A2845"/>

    <!-- Luminous ice blue — like starlight -->
    <SolidColorBrush x:Key="AccentBlue"      Color="#8EC8F6"/>
    <SolidColorBrush x:Key="AccentBlueDark"  Color="#6BA8E0"/>
    <SolidColorBrush x:Key="AccentBlueLight" Color="#0F2240"/>
    <!-- Success — soft aurora green -->
    <SolidColorBrush x:Key="AccentGreen"     Color="#4ADE80"/>
    <SolidColorBrush x:Key="AccentGreenDark" Color="#36C268"/>
    <SolidColorBrush x:Key="AccentGreenLight" Color="#0A2018"/>
    <!-- Danger — nebula red -->
    <SolidColorBrush x:Key="AccentRed"       Color="#FF6B7A"/>
    <SolidColorBrush x:Key="AccentRedDark"   Color="#E05060"/>
    <SolidColorBrush x:Key="AccentRedLight"  Color="#2A0D10"/>
    <!-- Amber — warm starlight gold -->
    <SolidColorBrush x:Key="AccentAmber"      Color="#FFD166"/>
    <SolidColorBrush x:Key="AccentAmberDark"  Color="#E0B84A"/>
    <SolidColorBrush x:Key="AccentAmberLight" Color="#281E08"/>

    <!-- Light text on very dark background -->
    <SolidColorBrush x:Key="TextPrimary"     Color="#E8EEFF"/>
    <SolidColorBrush x:Key="TextSecond"      Color="#BECAE8"/>
    <SolidColorBrush x:Key="TextMuted"       Color="#5A7090"/>
    <SolidColorBrush x:Key="TextDisabled"    Color="#2E3D58"/>
    <SolidColorBrush x:Key="TextOnAccent"    Color="#060A14"/>
    <SolidColorBrush x:Key="TextOnAccentBlueLight" Color="#8EC8F6"/>

    <!-- Borders: faint glowing seams -->
    <SolidColorBrush x:Key="Border"          Color="#1C2840"/>
    <SolidColorBrush x:Key="BorderFocus"     Color="#8EC8F6"/>

    <!-- Received: dark navy card; Sent: ice blue -->
    <SolidColorBrush x:Key="BubbleIn"        Color="#131A30"/>
    <SolidColorBrush x:Key="BubbleInBorder"  Color="#1C2840"/>
    <SolidColorBrush x:Key="BubbleOut"       Color="#1A3A60"/>
    <SolidColorBrush x:Key="BubbleOutText"   Color="#E8EEFF"/>

    <Color x:Key="ShadowColor">#80000000</Color>

</ResourceDictionary>
