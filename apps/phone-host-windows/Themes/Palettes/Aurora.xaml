<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Aurora — soft lavender, violet accent ─────────────────────────── -->
    <!-- Light mode. Pale lavender surfaces, rich violet accent, warm white   -->
    <!-- text areas. Soft and dreamy but fully readable.                      -->

    <SolidColorBrush x:Key="BgMain"          Color="#FDFCFF"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="#F3F0FA"/>
    <SolidColorBrush x:Key="BgHover"         Color="#EAE5F5"/>
    <SolidColorBrush x:Key="BgInput"         Color="#EEE9F8"/>
    <SolidColorBrush x:Key="BgSelected"      Color="#DDD4F7"/>

    <!-- Violet accent -->
    <SolidColorBrush x:Key="AccentBlue"      Color="#7C3AED"/>
    <SolidColorBrush x:Key="AccentBlueDark"  Color="#6025CC"/>
    <SolidColorBrush x:Key="AccentBlueLight" Color="#EDE8FB"/>
    <!-- Success — soft teal -->
    <SolidColorBrush x:Key="AccentGreen"     Color="#059669"/>
    <SolidColorBrush x:Key="AccentGreenDark" Color="#047857"/>
    <SolidColorBrush x:Key="AccentGreenLight" Color="#D1FAE5"/>
    <!-- Danger — rose -->
    <SolidColorBrush x:Key="AccentRed"       Color="#E11D48"/>
    <SolidColorBrush x:Key="AccentRedDark"   Color="#BE1B3E"/>
    <SolidColorBrush x:Key="AccentRedLight"  Color="#FFE4E9"/>
    <!-- Amber — gold -->
    <SolidColorBrush x:Key="AccentAmber"      Color="#D97706"/>
    <SolidColorBrush x:Key="AccentAmberDark"  Color="#B45309"/>
    <SolidColorBrush x:Key="AccentAmberLight" Color="#FEF3C7"/>

    <SolidColorBrush x:Key="TextPrimary"     Color="#1A1028"/>
    <SolidColorBrush x:Key="TextSecond"      Color="#3A2D55"/>
    <SolidColorBrush x:Key="TextMuted"       Color="#7B6EA0"/>
    <SolidColorBrush x:Key="TextDisabled"    Color="#C4BCE0"/>
    <SolidColorBrush x:Key="TextOnAccent"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnAccentBlueLight" Color="#4A1FA0"/>

    <SolidColorBrush x:Key="Border"          Color="#DDD6F0"/>
    <SolidColorBrush x:Key="BorderFocus"     Color="#7C3AED"/>

    <!-- Received: white; Sent: violet -->
    <SolidColorBrush x:Key="BubbleIn"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BubbleInBorder"  Color="#E4DDF5"/>
    <SolidColorBrush x:Key="BubbleOut"       Color="#7C3AED"/>
    <SolidColorBrush x:Key="BubbleOutText"   Color="#FFFFFF"/>

    <Color x:Key="ShadowColor">#28000000</Color>

</ResourceDictionary>
