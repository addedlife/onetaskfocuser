<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Claude / Anthropic — warm cream, coral accent ────────────────── -->
    <!-- Soft, classy, human. Cream backgrounds, warm coral/terracotta       -->
    <!-- accent, deep charcoal text. Feels like a very nice notebook.        -->

    <SolidColorBrush x:Key="Primary"             Color="#C96442"/>
    <SolidColorBrush x:Key="OnPrimary"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryContainer"    Color="#F7E4DA"/>
    <SolidColorBrush x:Key="OnPrimaryContainer"  Color="#71331F"/>

    <SolidColorBrush x:Key="Secondary"             Color="#67594D"/>
    <SolidColorBrush x:Key="OnSecondary"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SecondaryContainer"    Color="#EFE5DA"/>
    <SolidColorBrush x:Key="OnSecondaryContainer"  Color="#271A10"/>

    <SolidColorBrush x:Key="Tertiary"             Color="#5A7A5A"/>
    <SolidColorBrush x:Key="OnTertiary"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TertiaryContainer"    Color="#DCE8DC"/>
    <SolidColorBrush x:Key="OnTertiaryContainer"  Color="#152B17"/>

    <SolidColorBrush x:Key="Error"             Color="#BA2A2A"/>
    <SolidColorBrush x:Key="OnError"           Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ErrorContainer"    Color="#FFE1E1"/>
    <SolidColorBrush x:Key="OnErrorContainer"  Color="#5B1010"/>

    <SolidColorBrush x:Key="Background"              Color="#FAF9F6"/>
    <SolidColorBrush x:Key="OnBackground"            Color="#1A1611"/>
    <SolidColorBrush x:Key="Surface"                 Color="#FFFFFF"/>
    <SolidColorBrush x:Key="OnSurface"               Color="#1A1611"/>
    <SolidColorBrush x:Key="SurfaceVariant"          Color="#EAE6DC"/>
    <SolidColorBrush x:Key="OnSurfaceVariant"        Color="#51443A"/>
    <SolidColorBrush x:Key="SurfaceContainerLowest"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceContainerLow"     Color="#FDFBF8"/>
    <SolidColorBrush x:Key="SurfaceContainer"        Color="#F2EFE8"/>
    <SolidColorBrush x:Key="SurfaceContainerHigh"    Color="#EAE6DC"/>
    <SolidColorBrush x:Key="SurfaceContainerHighest" Color="#DDD8CF"/>
    <SolidColorBrush x:Key="Outline"                 Color="#7F746A"/>
    <SolidColorBrush x:Key="OutlineVariant"          Color="#DDD8CF"/>

    <SolidColorBrush x:Key="BgMain"          Color="#FAF9F6"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="#F2EFE8"/>
    <SolidColorBrush x:Key="BgHover"         Color="#EAE6DC"/>
    <SolidColorBrush x:Key="BgInput"         Color="#F0EDE6"/>
    <SolidColorBrush x:Key="BgSelected"      Color="#F5E6DC"/>

    <!-- Coral/terracotta accent — Anthropic brand orange-red -->
    <SolidColorBrush x:Key="AccentBlue"      Color="#C96442"/>
    <SolidColorBrush x:Key="AccentBlueDark"  Color="#A8502F"/>
    <SolidColorBrush x:Key="AccentBlueLight" Color="#FAE8DF"/>
    <!-- Success green — muted sage -->
    <SolidColorBrush x:Key="AccentGreen"     Color="#5A7A5A"/>
    <SolidColorBrush x:Key="AccentGreenDark" Color="#445E44"/>
    <SolidColorBrush x:Key="AccentGreenLight" Color="#DCE8DC"/>
    <!-- Danger — warm brick red -->
    <SolidColorBrush x:Key="AccentRed"       Color="#C0392B"/>
    <SolidColorBrush x:Key="AccentRedDark"   Color="#9B2D22"/>
    <SolidColorBrush x:Key="AccentRedLight"  Color="#FAE3DF"/>
    <!-- Amber — warm honey -->
    <SolidColorBrush x:Key="AccentAmber"      Color="#D4860A"/>
    <SolidColorBrush x:Key="AccentAmberDark"  Color="#A86A08"/>
    <SolidColorBrush x:Key="AccentAmberLight" Color="#FEF3DC"/>

    <SolidColorBrush x:Key="TextPrimary"     Color="#1A1611"/>
    <SolidColorBrush x:Key="TextSecond"      Color="#3D352A"/>
    <SolidColorBrush x:Key="TextMuted"       Color="#8A7E72"/>
    <SolidColorBrush x:Key="TextDisabled"    Color="#BEB5AA"/>
    <SolidColorBrush x:Key="TextOnAccent"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnAccentBlueLight" Color="#7A3020"/>

    <SolidColorBrush x:Key="Border"          Color="#DDD8CF"/>
    <SolidColorBrush x:Key="BorderFocus"     Color="#C96442"/>

    <!-- Received: warm white card; Sent: coral -->
    <SolidColorBrush x:Key="BubbleIn"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BubbleInBorder"  Color="#E4DED5"/>
    <SolidColorBrush x:Key="BubbleOut"       Color="#C96442"/>
    <SolidColorBrush x:Key="BubbleOutText"   Color="#FFFFFF"/>

    <Color x:Key="ShadowColor">#28000000</Color>

</ResourceDictionary>
