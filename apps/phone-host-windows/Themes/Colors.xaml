<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Material Design 3 colour tokens (Google Voice Theme) ────────── -->

    <!-- Background surfaces - lighter and airier -->
    <SolidColorBrush x:Key="BgMain"          Color="#FAFAFA"/>
    <SolidColorBrush x:Key="BgSidebar"       Color="#F8F9FA"/>
    <SolidColorBrush x:Key="BgHover"         Color="#F0F2F5"/>
    <SolidColorBrush x:Key="BgInput"         Color="#F5F7FA"/>
    <SolidColorBrush x:Key="BgSelected"      Color="#E8F0FE"/>

    <!-- Brand colours (Google palette) -->
    <SolidColorBrush x:Key="AccentBlue"      Color="#1A73E8"/>
    <SolidColorBrush x:Key="AccentBlueDark"  Color="#1557B0"/>
    <SolidColorBrush x:Key="AccentBlueLight" Color="#D2E3FC"/>
    <SolidColorBrush x:Key="AccentGreen"     Color="#1E8E3E"/>
    <SolidColorBrush x:Key="AccentGreenDark" Color="#137333"/>
    <SolidColorBrush x:Key="AccentGreenLight" Color="#CEEAD6"/>
    <SolidColorBrush x:Key="AccentRed"       Color="#D93025"/>
    <SolidColorBrush x:Key="AccentRedDark"   Color="#B31412"/>
    <SolidColorBrush x:Key="AccentRedLight"  Color="#FCE8E6"/>

    <SolidColorBrush x:Key="AccentAmber"      Color="#F29900"/>
    <SolidColorBrush x:Key="AccentAmberDark"  Color="#C77400"/>
    <SolidColorBrush x:Key="AccentAmberLight" Color="#FEF7E0"/>

    <!-- Text hierarchy -->
    <SolidColorBrush x:Key="TextPrimary"     Color="#202124"/>
    <SolidColorBrush x:Key="TextSecond"      Color="#3C4043"/>
    <SolidColorBrush x:Key="TextMuted"       Color="#5F6368"/>
    <SolidColorBrush x:Key="TextDisabled"    Color="#9AA0A6"/>
    <SolidColorBrush x:Key="TextOnAccent"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnAccentBlueLight" Color="#174EA6"/>

    <!-- Outline / dividers - very subtle -->
    <SolidColorBrush x:Key="Border"          Color="#E8EAED"/>
    <SolidColorBrush x:Key="BorderFocus"     Color="#1A73E8"/>

    <!-- Chat bubbles — received: subtle light bg, sent: Google blue -->
    <SolidColorBrush x:Key="BubbleIn"        Color="#F1F3F4"/>
    <SolidColorBrush x:Key="BubbleInBorder"  Color="#E8EAED"/>
    <SolidColorBrush x:Key="BubbleOut"       Color="#1A73E8"/>
    <SolidColorBrush x:Key="BubbleOutText"   Color="#FFFFFF"/>

    <Color x:Key="ShadowColor">#30000000</Color>

</ResourceDictionary>
